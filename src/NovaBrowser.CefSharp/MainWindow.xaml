                            <ItemsControl x:Name="AddonDetailScreenshots" />
                            <TextBlock Text="Berechtigungen" Foreground="{StaticResource NovaText}" FontSize="18" FontWeight="Black" Margin="0,24,0,10" />
                            <ItemsControl x:Name="AddonDetailPermissions" />
                            <TextBlock Text="Host-Berechtigungen" Foreground="{StaticResource NovaText}" FontSize="18" FontWeight="Black" Margin="0,24,0,10" />
                            <ItemsControl x:Name="AddonDetailHosts" />
                            <TextBlock Text="Changelog" Foreground="{StaticResource NovaText}" FontSize="18" FontWeight="Black" Margin="0,24,0,10" />
                            <TextBlock x:Name="AddonDetailChangelog" Text="" Foreground="{StaticResource MutedText}" TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <Border x:Name="GoogleNotice" Width="620" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,28" Background="#21142d" BorderBrush="#b967ff" BorderThickness="1" CornerRadius="12" Visibility="Collapsed">
                <StackPanel Margin="18">
                    <TextBlock Text="Google blockiert eingebettete Browser." Foreground="{StaticResource NovaText}" FontSize="17" FontWeight="Black" />
                    <TextBlock Text="Bitte extern anmelden oder OAuth verwenden. NovaBrowser versucht Google zuerst intern und nutzt keine unsicheren Tricks." Foreground="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,8,0,12" />
                    <Button Content="Schliessen" HorizontalAlignment="Right" Style="{StaticResource InternalButton}" Click="CloseGoogleNotice_Click" />
                </StackPanel>
            </Border>

            <Border x:Name="TrackerToast"
                    Width="260"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,22,22"
                    Background="#21142d"
                    BorderBrush="#b967ff"
                    BorderThickness="1"
                    CornerRadius="14"
                    Opacity="0"
                    Visibility="Collapsed"
                    IsHitTestVisible="False">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="0" Color="#a24cff" Opacity="0.45" />
                </Border.Effect>
                <StackPanel Margin="16,13">
                    <TextBlock x:Name="TrackerToastCount" Text="0 Tracker" Foreground="{StaticResource NovaText}" FontSize="18" FontWeight="Black" />
                    <TextBlock Text="Privacy Protection ist aktiv" Foreground="{StaticResource MutedText}" FontSize="12" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border x:Name="DownloadHud"
                    Width="320"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,22,96"
                    Background="#ea160f24"
                    BorderBrush="#b967ff"
                    BorderThickness="1.2"
                    CornerRadius="18"
                    Padding="14"
                    Visibility="Collapsed"
                    IsHitTestVisible="False">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="28" ShadowDepth="0" Color="#b967ff" Opacity="0.48" />
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="36" Height="36" CornerRadius="18" Background="#2c1741" BorderBrush="#b967ff" BorderThickness="1">
                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Download laeuft" Foreground="{StaticResource NovaText}" FontSize="14" FontWeight="Black" />
                        <TextBlock x:Name="DownloadHudFileText" Text="Datei wird vorbereitet..." Foreground="{StaticResource MutedText}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
                        <ProgressBar x:Name="DownloadHudProgress" Minimum="0" Maximum="100" Value="0" Style="{StaticResource NovaDownloadProgressBar}" Margin="0,8,0,0" />
                        <TextBlock x:Name="DownloadHudStatusText" Text="0%" Foreground="#dfc9ff" FontSize="11" Margin="0,5,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="BetaUpdateBanner"
                    Width="350"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,22,166"
                    Background="#ef181023"
                    BorderBrush="#b967ff"
                    BorderThickness="1.2"
                    CornerRadius="18"
                    Padding="14"
                    Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="#b967ff" Opacity="0.5" />
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="30" />
                    </Grid.ColumnDefinitions>
                    <Border Width="36" Height="36" CornerRadius="18" Background="#2c1741" BorderBrush="#b967ff" BorderThickness="1">
                        <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Beta-Update verfuegbar" Foreground="{StaticResource NovaText}" FontSize="14" FontWeight="Black" />
                        <TextBlock Text="NyxNova kann das Update im Hintergrund vorbereiten." Foreground="{StaticResource MutedText}" FontSize="12" TextWrapping="Wrap" Margin="0,3,0,8" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Starten" Style="{StaticResource NovaChipButton}" Click="StartBetaUpdate_Click" />
                            <Button Content="Details" Style="{StaticResource NovaChipButton}" Margin="8,0,0,0" Click="OpenUpdatePage_Click" />
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="2" Content="&#xE711;" FontFamily="Segoe MDL2 Assets" Style="{StaticResource MenuButton}" Width="28" Height="28" Padding="0" Click="DismissUpdateBanner_Click" />
                </Grid>
            </Border>
        </Grid>

        <Popup x:Name="ExtensionsPopupHost"
               PlacementTarget="{Binding ElementName=ExtensionsButton}"
               Placement="Bottom"
               HorizontalOffset="-322"
               VerticalOffset="8"
               AllowsTransparency="False"
               StaysOpen="False"
               DataContext="{Binding DataContext, ElementName=RootGrid}"
               IsOpen="{Binding Visibility, ElementName=ExtensionsPopup, Converter={StaticResource VisibilityToBooleanConverter}, Mode=TwoWay}">
        <Border x:Name="ExtensionsPopup"
                Width="360"
                Background="#dd15101f"
                BorderBrush="#a968ff"
                BorderThickness="1.2"
                CornerRadius="18"
                Visibility="Collapsed"
                DataContext="{Binding DataContext, ElementName=ExtensionsPopupHost}">
            <Border.Resources>
                <Style x:Key="ChromePopupIconButton" TargetType="Button">
                    <Setter Property="Width" Value="32" />
                    <Setter Property="Height" Value="32" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="2,0" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
                    <Setter Property="FontSize" Value="14" />
                    <Setter Property="Foreground" Value="#f3ecff" />
                    <Setter Property="Background" Value="#20172d" />
                    <Setter Property="BorderBrush" Value="#4b3568" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ChromeButtonRoot" CornerRadius="16" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ChromeButtonRoot" Property="Background" Value="#332246" />
                                        <Setter TargetName="ChromeButtonRoot" Property="BorderBrush" Value="#b967ff" />
                                        <Setter TargetName="ChromeButtonRoot" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="14" ShadowDepth="0" Color="#a968ff" Opacity="0.36" />
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="ChromeButtonRoot" Property="Background" Value="#4d2d73" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <Style x:Key="ChromePopupRowButton" TargetType="Button">
                    <Setter Property="Height" Value="42" />
                    <Setter Property="Padding" Value="18,0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="FontFamily" Value="Segoe UI" />
                    <Setter Property="FontSize" Value="13" />
                    <Setter Property="Foreground" Value="#f3ecff" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ChromeRowRoot" Background="{TemplateBinding Background}" CornerRadius="12">
                                    <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ChromeRowRoot" Property="Background" Value="#2b1d3b" />
                                        <Setter TargetName="ChromeRowRoot" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#a968ff" Opacity="0.22" />
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="ChromeRowRoot" Property="Background" Value="#3d2857" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Border.Resources>
            <Border.Effect>
                <DropShadowEffect BlurRadius="32" ShadowDepth="0" Color="#a968ff" Opacity="0.32" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="56" />
                    <RowDefinition Height="54" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="1" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="20,0,12,0">
                    <Button DockPanel.Dock="Right" Content="&#xE711;" Style="{StaticResource ChromePopupIconButton}" Click="CloseExtensionsPopup_Click" ToolTip="Schliessen" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Nova Addons" Foreground="{StaticResource NovaText}" FontSize="18" FontWeight="Black" />
                        <TextBlock Text="Erweiterungen fuer diese Seite" Foreground="#bfa9da" FontSize="11" Margin="0,2,0,0" />
                    </StackPanel>
                </DockPanel>
                <Border Grid.Row="0" VerticalAlignment="Bottom" Height="1" Background="#3b2c50" />

                <DockPanel Grid.Row="1" Margin="20,0,18,0">
                    <Button DockPanel.Dock="Right" Width="46" Height="24" Padding="0" Background="Transparent" BorderBrush="Transparent" Click="ExtensionAccessToggle_Click" ToolTip="Zugriff fuer diese Seite umschalten">
                        <Border Width="42" Height="22" CornerRadius="11" Background="{Binding ExtensionAccessToggleBrush}" BorderBrush="#8d62ca" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#a968ff" Opacity="0.34" />
                            </Border.Effect>
                            <Grid Margin="2">
                                <Ellipse Width="18" Height="18" Fill="#f3ecff" HorizontalAlignment="{Binding ExtensionAccessKnobAlignment}" />
                            </Grid>
                        </Border>
                    </Button>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentExtensionAccessText}" Foreground="{StaticResource NovaText}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding CurrentExtensionAccessHint}" Foreground="#bfa9da" FontSize="11" Margin="0,2,0,0" />
                    </StackPanel>
                </DockPanel>
                <Border Grid.Row="1" VerticalAlignment="Bottom" Height="1" Background="#3b2c50" />

                <ScrollViewer Grid.Row="2" MaxHeight="360" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="ExtensionsPopupAddonsList" ItemsSource="{Binding InstalledAddons}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#342843" BorderThickness="0,0,0,1" Padding="18,10" Background="Transparent" CornerRadius="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="38" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="72" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16" Background="#241832" BorderBrush="#a968ff" BorderThickness="1">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#a968ff" Opacity="0.24" />
                                            </Border.Effect>
                                            <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" Foreground="#f3ecff" FontSize="17" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource NovaText}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding PermissionSummary}" Foreground="#bfa9da" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Button Content="{Binding PinGlyph}" Tag="{Binding}" Style="{StaticResource ChromePopupIconButton}" Click="PinAddon_Click" ToolTip="Anheften oder loesen" />
                                            <Button Content="&#xE712;" Tag="{Binding}" Style="{StaticResource ChromePopupIconButton}" Click="AddonCardMenu_Click" ToolTip="Weitere Optionen" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Row="3" Background="#3b2c50" />

                <StackPanel Grid.Row="4" Margin="0,4,0,6">
                    <Button Style="{StaticResource ChromePopupRowButton}" Click="OpenExtensionsPage_Click">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="&#xE713;" FontFamily="Segoe MDL2 Assets" Foreground="#d8c4ff" Width="30" VerticalAlignment="Center" />
                            <TextBlock Text="Addons verwalten" Foreground="{StaticResource NovaText}" VerticalAlignment="Center" />
                        </DockPanel>
                    </Button>
                    <Button Style="{StaticResource ChromePopupRowButton}" Click="OpenStore_Click">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="&#xE719;" FontFamily="Segoe MDL2 Assets" Foreground="#d8c4ff" Width="30" VerticalAlignment="Center" />
                            <TextBlock Text="NovaStore oeffnen" Foreground="{StaticResource NovaText}" VerticalAlignment="Center" />
                        </DockPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        </Popup>

        <Popup x:Name="ExtensionActionPopupHost"
               PlacementTarget="{Binding ElementName=ExtensionsButton}"
               Placement="Bottom"
               HorizontalOffset="-230"
               VerticalOffset="70"
               AllowsTransparency="False"
               StaysOpen="False"
               DataContext="{Binding DataContext, ElementName=RootGrid}"
               IsOpen="{Binding Visibility, ElementName=ExtensionActionPopup, Converter={StaticResource VisibilityToBooleanConverter}, Mode=TwoWay}">
        <Border x:Name="ExtensionActionPopup" Width="230" MaxHeight="310" Background="#ee15101f" BorderBrush="#a968ff" BorderThickness="1" CornerRadius="14" Padding="8" Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect BlurRadius="22" ShadowDepth="0" Color="#a968ff" Opacity="0.30" />
            </Border.Effect>
            <StackPanel>
                <TextBlock x:Name="ExtensionActionTitle" Text="Extension" Foreground="{StaticResource NovaText}" FontSize="13" FontWeight="SemiBold" Margin="10,8,10,8" TextTrimming="CharacterEllipsis" />
                <Button Content="Details" Tag="{Binding}" Style="{StaticResource MenuButton}" Foreground="{StaticResource NovaText}" Background="Transparent" BorderBrush="Transparent" Click="AddonDetails_Click" />
                <Button Content="Optionen" Style="{StaticResource MenuButton}" Foreground="{StaticResource NovaText}" Background="Transparent" BorderBrush="Transparent" Click="AddonOptions_Click" />
                <Button x:Name="ExtensionPinMenuButton" Content="Anheften" Style="{StaticResource MenuButton}" Foreground="{StaticResource NovaText}" Background="Transparent" BorderBrush="Transparent" Click="PinSelectedAddon_Click" />
                <Button x:Name="ExtensionEnableMenuButton" Content="Deaktivieren" Style="{StaticResource MenuButton}" Foreground="{StaticResource NovaText}" Background="Transparent" BorderBrush="Transparent" Click="ToggleSelectedAddon_Click" />
                <Separator Margin="6" Background="#3b2c50" />
                <Button Content="Entfernen" Style="{StaticResource MenuButton}" Foreground="#b3261e" Background="Transparent" BorderBrush="Transparent" Click="RemoveSelectedAddon_Click" />
            </StackPanel>
        </Border>
        </Popup>

        <Popup x:Name="BookmarkPopupHost"
               PlacementTarget="{Binding ElementName=BookmarkButton}"
               Placement="Bottom"
               HorizontalOffset="-282"
               VerticalOffset="8"
               AllowsTransparency="False"
               StaysOpen="False"
               DataContext="{Binding DataContext, ElementName=RootGrid}"
               IsOpen="{Binding Visibility, ElementName=BookmarkPopup, Converter={StaticResource VisibilityToBooleanConverter}, Mode=TwoWay}">
        <Border x:Name="BookmarkPopup" Width="320" Background="{StaticResource NovaGlassPanel}" BorderBrush="#b967ff" BorderThickness="1" CornerRadius="18" Padding="16" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="Lesezeichen bearbeiten" Foreground="{StaticResource NovaText}" FontSize="18" FontWeight="Black" />
                <TextBlock x:Name="BookmarkHintText" Text="" Foreground="{StaticResource MutedText}" Margin="0,8,0,0" TextWrapping="Wrap" />
                <TextBlock Text="Name" Foreground="{StaticResource MutedText}" Margin="0,12,0,4" />
                <TextBox x:Name="BookmarkNameBox" Height="32" />
                <TextBlock Text="Ordner" Foreground="{StaticResource MutedText}" Margin="0,12,0,4" />
                <ComboBox x:Name="BookmarkFolderBox" Height="32">
                    <ComboBoxItem Content="Bookmarks" IsSelected="True" />
                    <ComboBoxItem Content="Work" />
                    <ComboBoxItem Content="Dev Resources" />
                    <ComboBoxItem Content="Design Inspiration" />
                </ComboBox>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                    <Button x:Name="BookmarkRemoveButton" Content="Entfernen" Margin="0,0,8,0" Click="RemoveBookmarkFromPopup_Click" />
                    <Button x:Name="BookmarkSaveButton" Content="Fertig" Click="SaveBookmarkFromPopup_Click" />
                </StackPanel>
            </StackPanel>
        </Border>
        </Popup>

        <Popup x:Name="DownloadsPopupHost"
               PlacementTarget="{Binding ElementName=DownloadsButton}"
               Placement="Bottom"
               HorizontalOffset="-342"
               VerticalOffset="8"
               AllowsTransparency="False"
               StaysOpen="True"
               DataContext="{Binding DataContext, ElementName=RootGrid}">
        <Border x:Name="DownloadsPopup" Width="390" MaxHeight="540" Background="{StaticResource NovaGlassPanel}" BorderBrush="#b967ff" BorderThickness="1.4" CornerRadius="20" Padding="16" Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28" ShadowDepth="0" Color="#9f4dff" Opacity="0.38" />
            </Border.Effect>
            <StackPanel>
                <DockPanel Margin="0,0,0,12">
                    <Border Width="34" Height="34" CornerRadius="17" DockPanel.Dock="Left" Background="#2b173d" BorderBrush="#9f61ff" BorderThickness="1">
                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" Foreground="#f6edff" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" />
                    </Border>
                    <StackPanel Margin="10,0,0,0">
                        <TextBlock Text="Downloads" Foreground="{StaticResource NovaText}" FontSize="19" FontWeight="Black" />
                        <TextBlock Text="Aktive und letzte Dateien" Foreground="{StaticResource MutedText}" FontSize="12" />
                    </StackPanel>
                </DockPanel>
                <TextBlock x:Name="DownloadsEmptyText" Text="Noch keine Downloads." Foreground="{StaticResource MutedText}" Margin="0,4,0,12" Visibility="Collapsed" />
                <ScrollViewer MaxHeight="390" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding RecentDownloads}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10" Margin="0,0,0,8" Background="#22152e" BorderBrush="#4f2f75" BorderThickness="1" CornerRadius="14">
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                                            <Button Content="&#xE8A7;" Tag="{Binding}" Click="OpenDownload_Click" Style="{StaticResource DownloadPopupIconButton}" ToolTip="Oeffnen" />
                                            <Button Content="&#xE8DA;" Tag="{Binding}" Click="ShowDownload_Click" Style="{StaticResource DownloadPopupIconButton}" ToolTip="Im Ordner anzeigen" />
                                            <Button Content="&#xE711;" Tag="{Binding}" Click="RemoveDownload_Click" Style="{StaticResource DownloadPopupIconButton}" ToolTip="Aus Liste entfernen" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="{Binding FileName}" Foreground="{StaticResource NovaText}" FontWeight="Bold" TextTrimming="CharacterEllipsis" MaxWidth="210" />
                                            <TextBlock Text="{Binding Status}" Foreground="{StaticResource MutedText}" FontSize="11" Margin="0,3,0,0" />
                                            <ProgressBar Value="{Binding Progress}" Maximum="100" Width="210" Margin="0,7,0,0" Style="{StaticResource NovaDownloadProgressBar}" />
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <Button Content="Alle Downloads anzeigen" Margin="0,8,0,0" Click="Downloads_Click" Style="{StaticResource NovaActionButton}" />
            </StackPanel>
        </Border>
        </Popup>

        <Popup x:Name="MenuPanelHost"
               PlacementTarget="{Binding ElementName=MainMenuButton}"
               Placement="Bottom"
               HorizontalOffset="-382"
               VerticalOffset="8"
               AllowsTransparency="False"
               StaysOpen="False"
               DataContext="{Binding DataContext, ElementName=RootGrid}"
               IsOpen="{Binding Visibility, ElementName=MenuPanel, Converter={StaticResource VisibilityToBooleanConverter}, Mode=TwoWay}">
        <ui:MainBrowserMenu x:Name="MenuPanel"
                            Visibility="Collapsed"
                            NewTabRequested="MainMenu_NewTabRequested"
                            NewWindowRequested="MainMenu_NewWindowRequested"
                            IncognitoRequested="MainMenu_IncognitoRequested"
                            ProfileRequested="MainMenu_ProfileRequested"
                            PasswordsRequested="MainMenu_PasswordsRequested"
                            HistoryRequested="MainMenu_HistoryRequested"
                            DownloadsRequested="MainMenu_DownloadsRequested"
                            BookmarksRequested="MainMenu_BookmarksRequested"
                            TabGroupsRequested="MainMenu_TabGroupsRequested"
                            ExtensionsRequested="MainMenu_ExtensionsRequested"
                            ClearDataRequested="MainMenu_ClearDataRequested"
                            ZoomOutRequested="MainMenu_ZoomOutRequested"
                            ZoomInRequested="MainMenu_ZoomInRequested"
                            FullscreenRequested="MainMenu_FullscreenRequested"
                            PrintRequested="MainMenu_PrintRequested"
                            LensRequested="MainMenu_LensRequested"
                            TranslateRequested="MainMenu_TranslateRequested"
                            FindEditRequested="MainMenu_FindEditRequested"
                            ShareRequested="MainMenu_ShareRequested"
                            MoreToolsRequested="MainMenu_MoreToolsRequested"
                            HelpRequested="MainMenu_HelpRequested"
                            SettingsRequested="MainMenu_SettingsRequested"
                            ExitRequested="MainMenu_ExitRequested" />
        </Popup>

        <Border x:Name="SlowLoadBar" Grid.Row="3" VerticalAlignment="Bottom" Margin="18" Background="#ee17121f" BorderBrush="#a968ff" BorderThickness="1" CornerRadius="16" Padding="14,10" Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect BlurRadius="22" ShadowDepth="0" Color="#a968ff" Opacity="0.28" />
            </Border.Effect>
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="14,0,0,0">
                    <Button Content="Neu laden" Style="{StaticResource InternalButton}" Click="ReloadSlowPage_Click" Margin="0,0,8,0" />
                    <Button Content="Ohne Schutz laden" Style="{StaticResource InternalButton}" Click="DisableProtectionForPage_Click" />
                    <Button Content="Cookies loeschen" Style="{StaticResource InternalButton}" Margin="8,0,0,0" Click="ClearCookiesForPage_Click" />
                    <Button Content="DevTools" Style="{StaticResource InternalButton}" Margin="8,0,0,0" Click="OpenDevTools_Click" />
                    <Button Content="Diagnose" Style="{StaticResource InternalButton}" Margin="8,0,0,0" Click="OpenDiagnostics_Click" />
                    <Button Content="Media" Style="{StaticResource InternalButton}" Margin="8,0,0,0" Click="OpenMediaDiagnostics_Click" />
                </StackPanel>
                <TextBlock x:Name="SlowLoadText"
                           Text="Diese Seite laedt ungewoehnlich lange. Pruefe Cookies, Tracker-Blocker oder Popups."
                           Foreground="{StaticResource NovaText}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />
            </DockPanel>
        </Border>

        <ContentControl x:Name="MediaProbeHost"
                        Grid.Row="3"
                        Width="1"
                        Height="1"
                        Opacity="0"
                        IsHitTestVisible="False"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top" />

        <Border x:Name="StatusBar" Grid.Row="4" Background="#202124" BorderBrush="#34313d" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusText" Text="Bereit" Foreground="{StaticResource MutedText}" VerticalAlignment="Center" Padding="14,0" FontSize="12" />
        </Border>
    </Grid>
    </Border>
</Window>
