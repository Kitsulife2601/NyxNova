                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource NovaCard}">
                                    <StackPanel>
                                        <TextBlock Text="Hardware / GPU" Foreground="{StaticResource MutedText}" FontWeight="Bold" />
