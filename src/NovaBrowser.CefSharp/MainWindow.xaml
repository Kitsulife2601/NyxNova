                        <StackPanel Width="820">
                            <Border Height="210" CornerRadius="30" Background="{StaticResource NovaFlameWash}" BorderBrush="#ff6a2b" BorderThickness="1.4" Padding="24">
                                <Grid>
                                    <Border Width="104" Height="104" CornerRadius="28" Background="{StaticResource NovaFireButton}" BorderBrush="#ffd7c2" BorderThickness="1" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock x:Name="AddonDetailIcon" Text="NA" Foreground="{StaticResource NovaText}" FontSize="30" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Margin="132,0,0,0" VerticalAlignment="Center">
                                        <TextBlock x:Name="AddonDetailName" Text="Addon" Foreground="{StaticResource NovaText}" FontSize="36" FontWeight="Black" />
                                        <TextBlock x:Name="AddonDetailDescription" Text="" Foreground="#ffd7c2" FontSize="15" TextWrapping="Wrap" Margin="0,8,0,0" />
