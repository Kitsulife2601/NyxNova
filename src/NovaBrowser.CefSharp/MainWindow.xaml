                                    <Border CornerRadius="16" Background="#1a101f" BorderBrush="#ff2f8f" BorderThickness="1.2" Padding="14" Margin="0,0,10,0">
                                        <StackPanel>
                                            <Border Height="72" CornerRadius="10" Background="#111018" BorderBrush="#ff2f8f" BorderThickness="1">
                                                <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" Foreground="#ff4ea7" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="Nova Neon" Foreground="{StaticResource NovaText}" FontWeight="Bold" Margin="0,10,0,2" />
                                            <TextBlock Text="Aktiv" Foreground="#ff79bd" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                    <Border CornerRadius="16" Background="#15101d" BorderBrush="#6a40a2" BorderThickness="1" Padding="14" Margin="0,0,10,0">
                                        <StackPanel>
                                            <Border Height="72" CornerRadius="10" Background="#0c0b12" BorderBrush="#8d62ca" BorderThickness="1">
                                                <TextBlock Text="&#xE771;" FontFamily="Segoe MDL2 Assets" Foreground="#b967ff" FontSize="25" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="Aurora" Foreground="{StaticResource NovaText}" FontWeight="Bold" Margin="0,10,0,2" />
                                            <TextBlock Text="Startseite" Foreground="#aa93c6" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                    <Border CornerRadius="16" Background="#15101d" BorderBrush="#3b2a55" BorderThickness="1" Padding="14" Margin="0,0,10,0">
                                        <StackPanel>
                                            <Border Height="72" CornerRadius="10" Background="#0c0b12" BorderBrush="#4b2d73" BorderThickness="1">
                                                <TextBlock Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets" Foreground="#8cc8ff" FontSize="25" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="Fokus" Foreground="{StaticResource NovaText}" FontWeight="Bold" Margin="0,10,0,2" />
                                            <TextBlock Text="Ruhig" Foreground="#aa93c6" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                    <Border CornerRadius="16" Background="#15101d" BorderBrush="#3b2a55" BorderThickness="1" Padding="14">
                                        <StackPanel>
                                            <Border Height="72" CornerRadius="10" Background="#0c0b12" BorderBrush="#4b2d73" BorderThickness="1">
                                                <TextBlock Text="&#xE793;" FontFamily="Segoe MDL2 Assets" Foreground="#ff7fd6" FontSize="25" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="Glas" Foreground="{StaticResource NovaText}" FontWeight="Bold" Margin="0,10,0,2" />
                                            <TextBlock Text="Panels" Foreground="#aa93c6" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <Border x:Name="SettingsSearchSection" Style="{StaticResource NovaCard}" Padding="22" Margin="0,0,0,16">
                                            <StackPanel>
                                                <DockPanel Margin="0,0,0,14">
                                                    <TextBlock Text="Suche" Foreground="{StaticResource NovaText}" FontSize="20" FontWeight="Black" />
                                                    <TextBlock DockPanel.Dock="Right" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" Foreground="#d9b8ff" FontSize="18" />
                                                </DockPanel>
                                                <TextBlock Text="Suchmaschine fuer Adressleiste und Startseite." Foreground="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,10" />
                                                <ComboBox x:Name="SettingsSearchEngineBox" Height="38" SelectionChanged="SettingsSearchEngineBox_SelectionChanged">
                                                    <ComboBoxItem Content="Google" />
                                                    <ComboBoxItem Content="DuckDuckGo" />
                                                    <ComboBoxItem Content="Bing" />
                                                </ComboBox>
                                            </StackPanel>
                                        </Border>

                                        <Border x:Name="SettingsStartSection" Style="{StaticResource NovaCard}" Padding="22" Margin="0,0,0,16">
                                            <StackPanel>
                                                <DockPanel Margin="0,0,0,14">
                                                    <TextBlock Text="Start und Oberflaeche" Foreground="{StaticResource NovaText}" FontSize="20" FontWeight="Black" />
                                                    <TextBlock DockPanel.Dock="Right" Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" Foreground="#d9b8ff" FontSize="18" />
                                                </DockPanel>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="Startseite" Foreground="{StaticResource NovaText}" FontWeight="SemiBold" />
                                                        <TextBlock Text="nova://start mit NyxNova Hintergrund" Foreground="{StaticResource MutedText}" FontSize="12" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="Aktiv" Foreground="#c987ff" FontWeight="Bold" VerticalAlignment="Center" />
                                                </Grid>
                                                <CheckBox x:Name="BookmarkBarCheckBox" Content="Lesezeichenleiste anzeigen" Foreground="{StaticResource NovaText}" Checked="BookmarkBarCheckBox_Changed" Unchecked="BookmarkBarCheckBox_Changed" />
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource NovaCard}" Padding="22">
                                            <StackPanel>
                                                <DockPanel Margin="0,0,0,14">
                                                    <TextBlock Text="Downloads" Foreground="{StaticResource NovaText}" FontSize="20" FontWeight="Black" />
                                                    <TextBlock DockPanel.Dock="Right" Text="&#xE896;" FontFamily="Segoe MDL2 Assets" Foreground="#d9b8ff" FontSize="18" />
                                                </DockPanel>
                                                <TextBlock Text="Dateien landen im Windows-Downloads-Ordner. Der Toolbar-Button zeigt laufende Downloads als Nova-Popup." Foreground="{StaticResource MutedText}" TextWrapping="Wrap" />
                                                <Button Content="Download-Seite oeffnen" Style="{StaticResource InternalButton}" HorizontalAlignment="Left" Margin="0,14,0,0" Click="Downloads_Click" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <Border x:Name="SettingsAddonsSection" Style="{StaticResource NovaCard}" Padding="22" Margin="0,0,0,16">
                                            <StackPanel>
                                                <DockPanel Margin="0,0,0,14">
                                                    <TextBlock Text="Nova Addons" Foreground="{StaticResource NovaText}" FontSize="20" FontWeight="Black" />
                                                    <TextBlock DockPanel.Dock="Right" Text="&#xECAA;" FontFamily="Segoe MDL2 Assets" Foreground="#d9b8ff" FontSize="18" />
                                                </DockPanel>
                                                <TextBlock Text="Erweiterungen, Store und gepinnte Addons bleiben getrennt von Quick Links." Foreground="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,12" />
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="Addons verwalten" Style="{StaticResource InternalButton}" Click="OpenExtensionsPage_Click" />
                                                    <Button Content="NovaStore" Style="{StaticResource InternalButton}" Margin="10,0,0,0" Click="OpenStore_Click" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <Border x:Name="SettingsPrivacySection" Style="{StaticResource NovaCard}" Padding="22" Margin="0,0,0,16">
                                            <StackPanel>
                                                <DockPanel Margin="0,0,0,14">
                                                    <TextBlock Text="Datenschutz und Medien" Foreground="{StaticResource NovaText}" FontSize="20" FontWeight="Black" />
                                                    <TextBlock DockPanel.Dock="Right" Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" Foreground="#d9b8ff" FontSize="18" />
                                                </DockPanel>
                                                <TextBlock Text="Persistente Cookies, Cache, LocalStorage und sichere CEF-WebSecurity bleiben aktiv. Media-Diagnose prueft MP4/H.264/AAC/WebM." Foreground="{StaticResource MutedText}" TextWrapping="Wrap" />
                                                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                                    <Button Content="Diagnose" Style="{StaticResource InternalButton}" Click="OpenDiagnostics_Click" />
                                                    <Button Content="Media" Style="{StaticResource InternalButton}" Margin="10,0,0,0" Click="OpenMediaDiagnostics_Click" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <Border x:Name="SettingsBuildSection" Style="{StaticResource NovaCard}" Padding="22">
                                            <StackPanel>
                                                <DockPanel Margin="0,0,0,14">
                                                    <TextBlock Text="Build und Beta Update" Foreground="{StaticResource NovaText}" FontSize="20" FontWeight="Black" />
                                                    <TextBlock DockPanel.Dock="Right" Text="&#xE895;" FontFamily="Segoe MDL2 Assets" Foreground="#d9b8ff" FontSize="18" />
                                                </DockPanel>
                                                <TextBlock x:Name="BuildInfoText" Text="Build-Version wird geladen..." Foreground="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,12" />
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="Update-Seite" Style="{StaticResource InternalButton}" Click="OpenUpdatePage_Click" />
                                                    <Button Content="Zuruecksetzen" Style="{StaticResource InternalButton}" Margin="10,0,0,0" Click="ResetSettings_Click" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>

                <Grid x:Name="UpdatePage" Visibility="Collapsed" Margin="80,42">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Width="760">
                            <Border Style="{StaticResource NovaCard}" Padding="28">
                                <StackPanel>
                                    <TextBlock Text="NyxNova Beta Update" Foreground="{StaticResource NovaText}" FontSize="36" FontWeight="Black" />
                                    <TextBlock Text="Updates laufen im Hintergrund. Du kannst weiter surfen, waehrend Nova das Beta-Paket vorbereitet." Foreground="{StaticResource MutedText}" FontSize="15" TextWrapping="Wrap" Margin="0,8,0,22" />
                                    <Border CornerRadius="24" Background="#241335" BorderBrush="#b967ff" BorderThickness="1.2" Padding="20">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="58" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="46" Height="46" CornerRadius="23" Background="#361456" BorderBrush="#d28cff" BorderThickness="1.2">
                                                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" Foreground="#f4e8ff" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding UpdateStatusText}" Foreground="{StaticResource NovaText}" FontSize="20" FontWeight="Black" />
                                                <TextBlock Text="{Binding UpdateDetailText}" Foreground="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,4,0,12" />
                                                <ProgressBar Minimum="0" Maximum="100" Value="{Binding UpdateProgress, Mode=OneWay}" Height="10" Style="{StaticResource NovaDownloadProgressBar}" />
                                                <TextBlock Text="{Binding UpdateProgressText}" Foreground="#dfc9ff" FontSize="12" Margin="0,8,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                                        <Button Content="{Binding UpdateActionText}" Style="{StaticResource InternalButton}" Click="StartBetaUpdate_Click" />
                                        <Button Content="Im Hintergrund laufen lassen" Style="{StaticResource InternalButton}" Margin="10,0,0,0" Click="HideUpdatePage_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Grid x:Name="ExtensionsPage" Visibility="Collapsed" Margin="80,42">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,18">
                        <TextBlock Text="Meine Nova Addons" Foreground="{StaticResource NovaText}" FontSize="36" FontWeight="Black" />
                        <TextBlock Text="Installierte Addons, Pins, Berechtigungen und Nova-Popups." Foreground="{StaticResource MutedText}" Margin="0,4,0,0" />
                            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                <TextBox x:Name="AddonSearchBox" Width="300" Height="34" VerticalContentAlignment="Center" Text="Addons suchen" GotFocus="AddonSearchBox_GotFocus" KeyUp="AddonSearchBox_KeyUp" />
                                <ComboBox x:Name="AddonFilterBox" Width="160" Height="34" Margin="12,0,0,0" SelectionChanged="AddonFilterBox_SelectionChanged">
                                    <ComboBoxItem Content="Alle" IsSelected="True" />
                                    <ComboBoxItem Content="Aktiviert" />
                                    <ComboBoxItem Content="Deaktiviert" />
                                    <ComboBoxItem Content="Angeheftet" />
                                </ComboBox>
                                <Button Content="NovaStore oeffnen" Style="{StaticResource NovaChipButton}" Margin="12,0,0,0" Click="OpenStore_Click" />
                                <Button Content="ZIP Addon installieren" Style="{StaticResource NovaChipButton}" Margin="12,0,0,0" Click="InstallZipAddon_Click" />
                            </StackPanel>
                        </StackPanel>
                        <ItemsControl x:Name="InstalledAddonsList" ItemsSource="{Binding InstalledAddons}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="380" Style="{StaticResource NovaCard}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource NovaText}" FontSize="17" FontWeight="Black" />
                                            <TextBlock Text="{Binding Description}" Foreground="{StaticResource MutedText}" Margin="0,8,0,10" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Version, StringFormat=Version {0}}" Foreground="{StaticResource MutedText}" />
                                            <TextBlock Text="{Binding Author, StringFormat=Autor: {0}}" Foreground="{StaticResource MutedText}" />
                                            <TextBlock Text="{Binding Category, StringFormat=Kategorie: {0}}" Foreground="{StaticResource MutedText}" />
                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                <Border CornerRadius="12" Background="#251943" BorderBrush="#b967ff" BorderThickness="1" Padding="9,4" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding Enabled, StringFormat=Status: {0}}" Foreground="#ead8ff" FontWeight="Bold" />
                                                </Border>
                                                <Border CornerRadius="12" Background="#22143a" BorderBrush="#b967ff" BorderThickness="1" Padding="9,4">
                                                    <TextBlock Text="{Binding Pinned, StringFormat=Pin: {0}}" Foreground="#e7d4ff" FontWeight="Bold" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="Berechtigungen:" Foreground="{StaticResource NovaText}" FontWeight="Bold" Margin="0,12,0,4" />
                                            <ItemsControl ItemsSource="{Binding Permissions}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" Foreground="{StaticResource MutedText}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Text="Host-Zugriff:" Foreground="{StaticResource NovaText}" FontWeight="Bold" Margin="0,12,0,4" />
                                            <ItemsControl ItemsSource="{Binding HostPermissions}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" Foreground="{StaticResource MutedText}" TextTrimming="CharacterEllipsis" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                                <Button Content="..." Tag="{Binding}" Style="{StaticResource MenuButton}" Click="AddonCardMenu_Click" />
                                                <Button Content="Enable/Disable" Tag="{Binding}" Style="{StaticResource MenuButton}" Click="ToggleAddon_Click" />
                                                <Button Content="Pin" Tag="{Binding}" Style="{StaticResource MenuButton}" Click="PinAddon_Click" />
                                                <Button Content="Details" Tag="{Binding}" Style="{StaticResource MenuButton}" Click="AddonDetails_Click" />
                                                <Button Content="Remove" Tag="{Binding}" Style="{StaticResource MenuButton}" Click="RemoveAddon_Click" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Grid>

                <Grid x:Name="StorePage" Visibility="Collapsed" Margin="80,42">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,18">
                            <Border Height="170" CornerRadius="28" Background="{StaticResource NovaFlameWash}" BorderBrush="#b967ff" BorderThickness="1.2" Padding="26" Margin="0,0,0,18">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="260" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="NovaStore" Foreground="#ffe4d4" FontSize="46" FontWeight="Black">
                                            <TextBlock.Effect>
                                                <DropShadowEffect BlurRadius="28" ShadowDepth="0" Color="#a855ff" Opacity="0.58" />
                                            </TextBlock.Effect>
                                        </TextBlock>
                                        <TextBlock Text="Addons fuer deinen Nova Browser" Foreground="#e7d4ff" FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0" />
                                    </StackPanel>
                                    <Border Grid.Column="1" CornerRadius="24" Background="#1b1022" BorderBrush="#b967ff" BorderThickness="1" Padding="18">
                                        <StackPanel>
                                            <TextBlock Text="Featured" Foreground="#ffb48d" FontWeight="Black" />
                                            <TextBlock Text="Theme Switcher" Foreground="{StaticResource NovaText}" FontSize="24" FontWeight="Black" Margin="0,8,0,0" />
                                            <TextBlock Text="Wechselt Nova-Farbstimmungen direkt im Browser." Foreground="{StaticResource MutedText}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="StoreSearchBox" Width="320" Height="34" VerticalContentAlignment="Center" Text="NovaStore durchsuchen" GotFocus="StoreSearchBox_GotFocus" KeyUp="StoreSearchBox_KeyUp" />
                                <ComboBox x:Name="StoreCategoryBox" Width="190" Height="34" Margin="12,0,0,0" SelectionChanged="StoreCategoryBox_SelectionChanged">
                                    <ComboBoxItem Content="Alle" IsSelected="True" />
                                    <ComboBoxItem Content="Produktivitaet" />
                                    <ComboBoxItem Content="Datenschutz" />
                                    <ComboBoxItem Content="Design" />
                                    <ComboBoxItem Content="Social" />
                                    <ComboBoxItem Content="Musik" />
                                    <ComboBoxItem Content="Entwickler" />
                                    <ComboBoxItem Content="Nova Tools" />
                                </ComboBox>
                            </StackPanel>
                            <WrapPanel Margin="0,14,0,0">
                                <Button Content="Produktivitaet" Style="{StaticResource NovaChipButton}" Tag="Produktivitaet" Click="StoreChip_Click" />
                                <Button Content="Datenschutz" Style="{StaticResource NovaChipButton}" Tag="Datenschutz" Click="StoreChip_Click" />
                                <Button Content="Design" Style="{StaticResource NovaChipButton}" Tag="Design" Click="StoreChip_Click" />
                                <Button Content="Social" Style="{StaticResource NovaChipButton}" Tag="Social" Click="StoreChip_Click" />
                                <Button Content="Musik" Style="{StaticResource NovaChipButton}" Tag="Musik" Click="StoreChip_Click" />
                                <Button Content="Entwickler" Style="{StaticResource NovaChipButton}" Tag="Entwickler" Click="StoreChip_Click" />
                                <Button Content="Nova Tools" Style="{StaticResource NovaChipButton}" Tag="Nova Tools" Click="StoreChip_Click" />
                            </WrapPanel>
                        </StackPanel>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="StoreAddonsList" ItemsSource="{Binding StoreAddons}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="330" Style="{StaticResource NovaCard}">
                                            <StackPanel>
                                                <Border Width="56" Height="56" CornerRadius="18" Background="{StaticResource NovaFireButton}" BorderBrush="#ead8ff" BorderThickness="1" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource NovaText}" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource NovaText}" FontSize="18" FontWeight="Black" Margin="0,12,0,0" />
                                                <TextBlock Text="{Binding Description}" Foreground="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,8,0,8" />
                                                <TextBlock Text="{Binding Author, StringFormat=Autor: {0}}" Foreground="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding Version, StringFormat=Version {0}}" Foreground="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding Rating, StringFormat=Bewertung {0:0.0}/5}" Foreground="{StaticResource MutedText}" />
                                                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                                    <Button Tag="{Binding}" Style="{StaticResource InstallAddonButton}" Click="InstallAddon_Click" />
                                                    <Button Content="Details" Tag="{Binding}" Style="{StaticResource MenuButton}" Click="AddonDetails_Click" />
                                                    <Button Content="Verwalten" Tag="{Binding}" Style="{StaticResource MenuButton}" Click="ManageAddon_Click" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Grid>

                <Grid x:Name="ModsPage" Visibility="Collapsed" Margin="80,42">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Width="860">
                            <TextBlock Text="NX Mods" Foreground="{StaticResource NovaText}" FontSize="38" FontWeight="Black" Margin="0,0,0,6" />
                            <TextBlock Text="Ein Nova-Bereich fuer Browser-Mods, Oberflaechen-Module und spaetere Community-Pakete." Foreground="{StaticResource MutedText}" FontSize="15" Margin="0,0,0,24" />
                            <UniformGrid Columns="3">
                                <Border Style="{StaticResource NovaCard}">
                                    <StackPanel>
                                        <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" Foreground="#c08cff" FontSize="30" />
                                        <TextBlock Text="UI Mods" Foreground="{StaticResource NovaText}" FontSize="20" FontWeight="Black" Margin="0,12,0,6" />
                                        <TextBlock Text="Layouts, Panels und Schnellzugriffe fuer den Nova-Browser." Foreground="{StaticResource MutedText}" TextWrapping="Wrap" />
                                        <Button Content="Vorbereitet" Style="{StaticResource NovaChipButton}" Margin="0,16,0,0" IsEnabled="False" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource NovaCard}">
                                    <StackPanel>
                                        <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" Foreground="#c08cff" FontSize="30" />
                                        <TextBlock Text="Sound Mods" Foreground="{StaticResource NovaText}" FontSize="20" FontWeight="Black" Margin="0,12,0,6" />
                                        <TextBlock Text="Spaeter fuer eigene Sounds, Feedback und dezente Browser-Effekte." Foreground="{StaticResource MutedText}" TextWrapping="Wrap" />
                                        <Button Content="In Planung" Style="{StaticResource NovaChipButton}" Margin="0,16,0,0" IsEnabled="False" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource NovaCard}">
                                    <StackPanel>
                                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" Foreground="#c08cff" FontSize="30" />
                                        <TextBlock Text="Mod-Verwaltung" Foreground="{StaticResource NovaText}" FontSize="20" FontWeight="Black" Margin="0,12,0,6" />
                                        <TextBlock Text="Aktivieren, deaktivieren und verwalten wird hier gesammelt." Foreground="{StaticResource MutedText}" TextWrapping="Wrap" />
                                        <Button Content="Manager offen" Style="{StaticResource NovaChipButton}" Margin="0,16,0,0" IsEnabled="False" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Grid x:Name="ShadersPage" Visibility="Collapsed" Margin="80,42">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Width="760">
                            <TextBlock Text="NX Shader" Foreground="{StaticResource NovaText}" FontSize="38" FontWeight="Black" Margin="0,0,0,6" />
                            <TextBlock Text="Visuelle Nova-Effekte fuer die Browser-Oberflaeche. Aktuell nur als Design-Bereich vorbereitet." Foreground="{StaticResource MutedText}" FontSize="15" Margin="0,0,0,24" />
                            <Border Style="{StaticResource NovaCard}" Width="720">
                                <StackPanel>
                                    <TextBlock Text="Shader-Auswahl" Foreground="{StaticResource NovaText}" FontSize="20" FontWeight="Black" Margin="0,0,0,14" />
                                    <RadioButton Content="Kein Shader" Foreground="{StaticResource NovaText}" IsChecked="True" Margin="0,8" />
                                    <RadioButton Content="Nova Glow" Foreground="{StaticResource NovaText}" Margin="0,8" />
                                    <RadioButton Content="Aurora Soft" Foreground="{StaticResource NovaText}" Margin="0,8" />
                                    <RadioButton Content="Violet Grid" Foreground="{StaticResource NovaText}" Margin="0,8" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource NovaCard}" Width="720">
                                <StackPanel>
                                    <TextBlock Text="Hinweis" Foreground="{StaticResource NovaText}" FontSize="18" FontWeight="Black" />
                                    <TextBlock Text="Shader werden erst aktiv geschaltet, wenn die Performance stabil bleibt. Alles bleibt auf Nova-Basis." Foreground="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Grid x:Name="AddonDetailPage" Visibility="Collapsed" Margin="80,42">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Width="820">
                            <Border Height="210" CornerRadius="30" Background="{StaticResource NovaFlameWash}" BorderBrush="#b967ff" BorderThickness="1.4" Padding="24">
                                <Grid>
                                    <Border Width="104" Height="104" CornerRadius="28" Background="{StaticResource NovaFireButton}" BorderBrush="#ead8ff" BorderThickness="1" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock x:Name="AddonDetailIcon" Text="NA" Foreground="{StaticResource NovaText}" FontSize="30" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Margin="132,0,0,0" VerticalAlignment="Center">
                                        <TextBlock x:Name="AddonDetailName" Text="Addon" Foreground="{StaticResource NovaText}" FontSize="36" FontWeight="Black" />
                                        <TextBlock x:Name="AddonDetailDescription" Text="" Foreground="#ead8ff" FontSize="15" TextWrapping="Wrap" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                                <Button x:Name="AddonDetailInstallButton" Content="Installieren" Style="{StaticResource InternalButton}" Click="AddonDetailInstall_Click" />
                                <Button Content="Zurueck zum Store" Style="{StaticResource InternalButton}" Margin="12,0,0,0" Click="OpenStore_Click" />
                            </StackPanel>
                            <TextBlock x:Name="AddonDetailMeta" Text="" Foreground="{StaticResource MutedText}" Margin="0,20,0,0" />
                            <TextBlock Text="Screenshots" Foreground="{StaticResource NovaText}" FontSize="18" FontWeight="Black" Margin="0,24,0,10" />
                            <ItemsControl x:Name="AddonDetailScreenshots" />
                            <TextBlock Text="Berechtigungen" Foreground="{StaticResource NovaText}" FontSize="18" FontWeight="Black" Margin="0,24,0,10" />
                            <ItemsControl x:Name="AddonDetailPermissions" />
                            <TextBlock Text="Host-Berechtigungen" Foreground="{StaticResource NovaText}" FontSize="18" FontWeight="Black" Margin="0,24,0,10" />
                            <ItemsControl x:Name="AddonDetailHosts" />
                            <TextBlock Text="Changelog" Foreground="{StaticResource NovaText}" FontSize="18" FontWeight="Black" Margin="0,24,0,10" />
                            <TextBlock x:Name="AddonDetailChangelog" Text="" Foreground="{StaticResource MutedText}" TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <Border x:Name="GoogleNotice" Width="620" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,28" Background="#21142d" BorderBrush="#b967ff" BorderThickness="1" CornerRadius="12" Visibility="Collapsed">
                <StackPanel Margin="18">
                    <TextBlock Text="Google blockiert eingebettete Browser." Foreground="{StaticResource NovaText}" FontSize="17" FontWeight="Black" />
                    <TextBlock Text="Bitte extern anmelden oder OAuth verwenden. NovaBrowser versucht Google zuerst intern und nutzt keine unsicheren Tricks." Foreground="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,8,0,12" />
                    <Button Content="Schliessen" HorizontalAlignment="Right" Style="{StaticResource InternalButton}" Click="CloseGoogleNotice_Click" />
                </StackPanel>
            </Border>

            <Border x:Name="TrackerToast"
                    Width="260"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,22,22"
                    Background="#21142d"
                    BorderBrush="#b967ff"
                    BorderThickness="1"
                    CornerRadius="14"
                    Opacity="0"
                    Visibility="Collapsed"
                    IsHitTestVisible="False">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="0" Color="#a24cff" Opacity="0.45" />
                </Border.Effect>
                <StackPanel Margin="16,13">
                    <TextBlock x:Name="TrackerToastCount" Text="0 Tracker" Foreground="{StaticResource NovaText}" FontSize="18" FontWeight="Black" />
                    <TextBlock Text="Privacy Protection ist aktiv" Foreground="{StaticResource MutedText}" FontSize="12" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border x:Name="GoogleAuthToast"
                    Width="300"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,22,22"
                    Background="#ea160f24"
                    BorderBrush="#b967ff"
                    BorderThickness="1.2"
                    CornerRadius="16"
                    Opacity="0"
                    Visibility="Collapsed"
                    IsHitTestVisible="False">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="26" ShadowDepth="0" Color="#b967ff" Opacity="0.45" />
                </Border.Effect>
                <StackPanel Margin="16,13">
                    <TextBlock x:Name="GoogleAuthToastTitle" Text="Google wird geprueft" Foreground="{StaticResource NovaText}" FontSize="16" FontWeight="Black" />
                    <TextBlock x:Name="GoogleAuthToastHint" Text="Nova prueft die echte Sitzung." Foreground="{StaticResource MutedText}" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border x:Name="DownloadHud"
                    Width="320"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,22,96"
                    Background="#ea160f24"
                    BorderBrush="#b967ff"
                    BorderThickness="1.2"
                    CornerRadius="18"
                    Padding="14"
                    Visibility="Collapsed"
                    IsHitTestVisible="False">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="28" ShadowDepth="0" Color="#b967ff" Opacity="0.48" />
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="36" Height="36" CornerRadius="18" Background="#2c1741" BorderBrush="#b967ff" BorderThickness="1">
                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Download laeuft" Foreground="{StaticResource NovaText}" FontSize="14" FontWeight="Black" />
                        <TextBlock x:Name="DownloadHudFileText" Text="Datei wird vorbereitet..." Foreground="{StaticResource MutedText}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
                        <ProgressBar x:Name="DownloadHudProgress" Minimum="0" Maximum="100" Value="0" Style="{StaticResource NovaDownloadProgressBar}" Margin="0,8,0,0" />
                        <TextBlock x:Name="DownloadHudStatusText" Text="0%" Foreground="#dfc9ff" FontSize="11" Margin="0,5,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="BetaUpdateBanner"
                    Width="420"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,24,158"
                    Background="#f20b0711"
                    BorderBrush="#b967ff"
                    BorderThickness="1.25"
                    CornerRadius="24"
                    Padding="0"
                    Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="42" ShadowDepth="0" Color="#a855ff" Opacity="0.42" />
                </Border.Effect>
                <Grid ClipToBounds="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Height="4" VerticalAlignment="Top" CornerRadius="24,24,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#8f42ff" Offset="0" />
                                <GradientStop Color="#b657ff" Offset="0.55" />
                                <GradientStop Color="#27e7ff" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <Grid Grid.Row="1" Margin="18,18,14,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="34" />
                        </Grid.ColumnDefinitions>

                        <Grid Width="48" Height="48" HorizontalAlignment="Left" VerticalAlignment="Top">
                            <Ellipse Stroke="#b967ff" StrokeThickness="1.4" Opacity="0.9" />
                            <Ellipse Stroke="#27e7ff" StrokeThickness="2.4" StrokeDashArray="4 5" Opacity="0.82">
                                <Ellipse.RenderTransform>
                                    <RotateTransform Angle="-18" CenterX="24" CenterY="24" />
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Border Width="34" Height="34" CornerRadius="17" Background="#261943" BorderBrush="#b967ff" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" />
                            </Border>
                        </Grid>

                        <StackPanel Grid.Column="1" Margin="8,0,8,0">
                            <TextBlock Text="Neues NyxNova Update" Foreground="{StaticResource NovaText}" FontSize="18" FontWeight="Black" />
                            <TextBlock Text="Eine neue Beta kann vorbereitet werden. Der Download laeuft im Hintergrund und du kannst weiter surfen." Foreground="{StaticResource MutedText}" FontSize="12.5" TextWrapping="Wrap" Margin="0,4,0,12" />
                            <Grid Margin="0,0,0,13">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Background="#2a1322" BorderBrush="#65304d" BorderThickness="1" CornerRadius="10" Padding="9,5">
                                    <TextBlock Text="BETA" Foreground="#ff8aae" FontSize="11" FontWeight="Black" />
                                </Border>
                                <TextBlock Grid.Column="1" Text="Bereit zum Testen" Foreground="#dfd2e7" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0" />
                            </Grid>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Jetzt aktualisieren" Style="{StaticResource NovaChipButton}" Click="StartBetaUpdate_Click" />
                                <Button Content="Mehr Infos" Style="{StaticResource NovaChipButton}" Margin="8,0,0,0" Click="OpenUpdatePage_Click" />
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="2" Content="&#xE711;" FontFamily="Segoe MDL2 Assets" Foreground="#ffd7e2" Background="#25111b" BorderBrush="#523044" BorderThickness="1" Width="30" Height="30" Padding="0" Click="DismissUpdateBanner_Click" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Popup x:Name="ExtensionsPopupHost"
               PlacementTarget="{Binding ElementName=ExtensionsButton}"
               Placement="Bottom"
               HorizontalOffset="-336"
               VerticalOffset="8"
               AllowsTransparency="True"
               StaysOpen="False"
               DataContext="{Binding DataContext, ElementName=RootGrid}"
               IsOpen="{Binding Visibility, ElementName=ExtensionsPopup, Converter={StaticResource VisibilityToBooleanConverter}, Mode=TwoWay}">
        <Border x:Name="ExtensionsPopup"
                Width="374"
                Background="#f215101f"
                BorderBrush="#a968ff"
                BorderThickness="1.4"
                CornerRadius="20"
                Visibility="Collapsed"
                DataContext="{Binding DataContext, ElementName=ExtensionsPopupHost}">
            <Border.Resources>
                <Style x:Key="ChromePopupIconButton" TargetType="Button">
                    <Setter Property="Width" Value="32" />
                    <Setter Property="Height" Value="32" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="2,0" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
                    <Setter Property="FontSize" Value="14" />
                    <Setter Property="Foreground" Value="#f3ecff" />
                    <Setter Property="Background" Value="#261934" />
                    <Setter Property="BorderBrush" Value="#6f4a98" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ChromeButtonRoot" CornerRadius="16" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ChromeButtonRoot" Property="Background" Value="#3b2354" />
                                        <Setter TargetName="ChromeButtonRoot" Property="BorderBrush" Value="#b967ff" />
                                        <Setter TargetName="ChromeButtonRoot" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="14" ShadowDepth="0" Color="#a968ff" Opacity="0.36" />
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="ChromeButtonRoot" Property="Background" Value="#4d2d73" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <Style x:Key="ChromePopupRowButton" TargetType="Button">
                    <Setter Property="Height" Value="40" />
                    <Setter Property="Padding" Value="18,0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="FontFamily" Value="Segoe UI" />
                    <Setter Property="FontSize" Value="13" />
                    <Setter Property="Foreground" Value="#f3ecff" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ChromeRowRoot" Background="{TemplateBinding Background}" CornerRadius="12">
                                    <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ChromeRowRoot" Property="Background" Value="#2c1b3d" />
                                        <Setter TargetName="ChromeRowRoot" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#a968ff" Opacity="0.22" />
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="ChromeRowRoot" Property="Background" Value="#3d2857" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Border.Resources>
            <Border.Effect>
                <DropShadowEffect BlurRadius="34" ShadowDepth="0" Color="#a968ff" Opacity="0.44" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="58" />
                    <RowDefinition Height="56" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="1" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="20,0,12,0">
                    <Button DockPanel.Dock="Right" Content="&#xE711;" Style="{StaticResource ChromePopupIconButton}" Click="CloseExtensionsPopup_Click" ToolTip="Schliessen" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Nova Addons" Foreground="{StaticResource NovaText}" FontSize="19" FontWeight="Black" />
                        <TextBlock Text="Erweiterungen fuer diese Seite" Foreground="#bfa9da" FontSize="11" Margin="0,2,0,0" />
                    </StackPanel>
                </DockPanel>
                <Border Grid.Row="0" VerticalAlignment="Bottom" Height="1" Background="#3b2c50" />

                <DockPanel Grid.Row="1" Margin="20,0,18,0">
                    <Button DockPanel.Dock="Right" Width="46" Height="24" Padding="0" Background="Transparent" BorderBrush="Transparent" Click="ExtensionAccessToggle_Click" ToolTip="Zugriff fuer diese Seite umschalten">
                        <Border Width="42" Height="22" CornerRadius="11" Background="{Binding ExtensionAccessToggleBrush}" BorderBrush="#8d62ca" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#a968ff" Opacity="0.34" />
                            </Border.Effect>
                            <Grid Margin="2">
                                <Ellipse Width="18" Height="18" Fill="#f3ecff" HorizontalAlignment="{Binding ExtensionAccessKnobAlignment}" />
                            </Grid>
                        </Border>
                    </Button>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentExtensionAccessText}" Foreground="{StaticResource NovaText}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding CurrentExtensionAccessHint}" Foreground="#bfa9da" FontSize="11" Margin="0,2,0,0" />
                    </StackPanel>
                </DockPanel>
                <Border Grid.Row="1" VerticalAlignment="Bottom" Height="1" Background="#3b2c50" />

                <ScrollViewer Grid.Row="2" MaxHeight="420" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="ExtensionsPopupAddonsList" ItemsSource="{Binding InstalledAddons}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#342843" BorderThickness="0,0,0,1" Padding="18,10" Background="Transparent" CornerRadius="14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="72" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="34" Height="34" CornerRadius="17" Background="#241832" BorderBrush="#a968ff" BorderThickness="1">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#a968ff" Opacity="0.24" />
                                            </Border.Effect>
                                            <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" Foreground="#f3ecff" FontSize="17" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource NovaText}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding PermissionSummary}" Foreground="#bfa9da" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Button Content="{Binding PinGlyph}" Tag="{Binding}" Style="{StaticResource ChromePopupIconButton}" Click="PinAddon_Click" ToolTip="Anheften oder loesen" />
                                            <Button Content="&#xE712;" Tag="{Binding}" Style="{StaticResource ChromePopupIconButton}" Click="AddonCardMenu_Click" ToolTip="Weitere Optionen" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Row="3" Background="#3b2c50" />

                <StackPanel Grid.Row="4" Margin="0,5,0,7">
                    <Button Style="{StaticResource ChromePopupRowButton}" Click="OpenExtensionsPage_Click">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="&#xE713;" FontFamily="Segoe MDL2 Assets" Foreground="#d8c4ff" Width="30" VerticalAlignment="Center" />
                            <TextBlock Text="Addons verwalten" Foreground="{StaticResource NovaText}" VerticalAlignment="Center" />
                        </DockPanel>
                    </Button>
                    <Button Style="{StaticResource ChromePopupRowButton}" Click="OpenStore_Click">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="&#xE719;" FontFamily="Segoe MDL2 Assets" Foreground="#d8c4ff" Width="30" VerticalAlignment="Center" />
                            <TextBlock Text="NovaStore oeffnen" Foreground="{StaticResource NovaText}" VerticalAlignment="Center" />
                        </DockPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        </Popup>

        <Popup x:Name="ExtensionActionPopupHost"
               PlacementTarget="{Binding ElementName=ExtensionsButton}"
               Placement="Bottom"
               HorizontalOffset="-244"
               VerticalOffset="70"
               AllowsTransparency="True"
               StaysOpen="False"
               DataContext="{Binding DataContext, ElementName=RootGrid}"
               IsOpen="{Binding Visibility, ElementName=ExtensionActionPopup, Converter={StaticResource VisibilityToBooleanConverter}, Mode=TwoWay}">
        <Border x:Name="ExtensionActionPopup" Width="246" MaxHeight="330" Background="#f215101f" BorderBrush="#a968ff" BorderThickness="1.2" CornerRadius="16" Padding="8" Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect BlurRadius="26" ShadowDepth="0" Color="#a968ff" Opacity="0.42" />
            </Border.Effect>
            <StackPanel>
                <TextBlock x:Name="ExtensionActionTitle" Text="Extension" Foreground="{StaticResource NovaText}" FontSize="13" FontWeight="SemiBold" Margin="10,8,10,8" TextTrimming="CharacterEllipsis" />
                <Button Content="Details" Tag="{Binding}" Style="{StaticResource MenuButton}" Foreground="{StaticResource NovaText}" Background="Transparent" BorderBrush="Transparent" Click="AddonDetails_Click" />
                <Button Content="Optionen" Style="{StaticResource MenuButton}" Foreground="{StaticResource NovaText}" Background="Transparent" BorderBrush="Transparent" Click="AddonOptions_Click" />
                <Button x:Name="ExtensionPinMenuButton" Content="Anheften" Style="{StaticResource MenuButton}" Foreground="{StaticResource NovaText}" Background="Transparent" BorderBrush="Transparent" Click="PinSelectedAddon_Click" />
                <Button x:Name="ExtensionEnableMenuButton" Content="Deaktivieren" Style="{StaticResource MenuButton}" Foreground="{StaticResource NovaText}" Background="Transparent" BorderBrush="Transparent" Click="ToggleSelectedAddon_Click" />
                <Separator Margin="6" Background="#3b2c50" />
                <Button Content="Entfernen" Style="{StaticResource MenuButton}" Foreground="#b3261e" Background="Transparent" BorderBrush="Transparent" Click="RemoveSelectedAddon_Click" />
            </StackPanel>
        </Border>
        </Popup>

        <Popup x:Name="BookmarkPopupHost"
               PlacementTarget="{Binding ElementName=BookmarkButton}"
               Placement="Bottom"
               HorizontalOffset="-282"
               VerticalOffset="8"
               AllowsTransparency="False"
               StaysOpen="False"
               DataContext="{Binding DataContext, ElementName=RootGrid}"
               IsOpen="{Binding Visibility, ElementName=BookmarkPopup, Converter={StaticResource VisibilityToBooleanConverter}, Mode=TwoWay}">
        <Border x:Name="BookmarkPopup" Width="320" Background="{StaticResource NovaGlassPanel}" BorderBrush="#b967ff" BorderThickness="1" CornerRadius="18" Padding="16" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="Lesezeichen bearbeiten" Foreground="{StaticResource NovaText}" FontSize="18" FontWeight="Black" />
                <TextBlock x:Name="BookmarkHintText" Text="" Foreground="{StaticResource MutedText}" Margin="0,8,0,0" TextWrapping="Wrap" />
                <TextBlock Text="Name" Foreground="{StaticResource MutedText}" Margin="0,12,0,4" />
                <TextBox x:Name="BookmarkNameBox" Height="32" />
                <TextBlock Text="Ordner" Foreground="{StaticResource MutedText}" Margin="0,12,0,4" />
                <ComboBox x:Name="BookmarkFolderBox" Height="32">
                    <ComboBoxItem Content="Bookmarks" IsSelected="True" />
                    <ComboBoxItem Content="Work" />
                    <ComboBoxItem Content="Dev Resources" />
                    <ComboBoxItem Content="Design Inspiration" />
                </ComboBox>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                    <Button x:Name="BookmarkRemoveButton" Content="Entfernen" Margin="0,0,8,0" Click="RemoveBookmarkFromPopup_Click" />
                    <Button x:Name="BookmarkSaveButton" Content="Fertig" Click="SaveBookmarkFromPopup_Click" />
                </StackPanel>
            </StackPanel>
        </Border>
        </Popup>

        <Popup x:Name="DownloadsPopupHost"
               PlacementTarget="{Binding ElementName=DownloadsButton}"
               Placement="Bottom"
               HorizontalOffset="-342"
               VerticalOffset="8"
               AllowsTransparency="False"
               StaysOpen="True"
               DataContext="{Binding DataContext, ElementName=RootGrid}">
        <Border x:Name="DownloadsPopup" Width="390" MaxHeight="540" Background="{StaticResource NovaGlassPanel}" BorderBrush="#b967ff" BorderThickness="1.4" CornerRadius="20" Padding="16" Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28" ShadowDepth="0" Color="#9f4dff" Opacity="0.38" />
            </Border.Effect>
            <StackPanel>
                <DockPanel Margin="0,0,0,12">
                    <Border Width="34" Height="34" CornerRadius="17" DockPanel.Dock="Left" Background="#2b173d" BorderBrush="#9f61ff" BorderThickness="1">
                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" Foreground="#f6edff" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" />
                    </Border>
                    <StackPanel Margin="10,0,0,0">
                        <TextBlock Text="Downloads" Foreground="{StaticResource NovaText}" FontSize="19" FontWeight="Black" />
                        <TextBlock Text="Aktive und letzte Dateien" Foreground="{StaticResource MutedText}" FontSize="12" />
                    </StackPanel>
                </DockPanel>
                <TextBlock x:Name="DownloadsEmptyText" Text="Noch keine Downloads." Foreground="{StaticResource MutedText}" Margin="0,4,0,12" Visibility="Collapsed" />
                <ScrollViewer MaxHeight="390" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding RecentDownloads}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10" Margin="0,0,0,8" Background="#22152e" BorderBrush="#4f2f75" BorderThickness="1" CornerRadius="14">
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                                            <Button Content="&#xE8A7;" Tag="{Binding}" Click="OpenDownload_Click" Style="{StaticResource DownloadPopupIconButton}" ToolTip="Oeffnen" />
                                            <Button Content="&#xE8DA;" Tag="{Binding}" Click="ShowDownload_Click" Style="{StaticResource DownloadPopupIconButton}" ToolTip="Im Ordner anzeigen" />
                                            <Button Content="&#xE711;" Tag="{Binding}" Click="RemoveDownload_Click" Style="{StaticResource DownloadPopupIconButton}" ToolTip="Aus Liste entfernen" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="{Binding FileName}" Foreground="{StaticResource NovaText}" FontWeight="Bold" TextTrimming="CharacterEllipsis" MaxWidth="210" />
                                            <TextBlock Text="{Binding Status}" Foreground="{StaticResource MutedText}" FontSize="11" Margin="0,3,0,0" />
                                            <ProgressBar Value="{Binding Progress}" Maximum="100" Width="210" Margin="0,7,0,0" Style="{StaticResource NovaDownloadProgressBar}" />
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <Button Content="Alle Downloads anzeigen" Margin="0,8,0,0" Click="Downloads_Click" Style="{StaticResource NovaActionButton}" />
            </StackPanel>
        </Border>
        </Popup>

