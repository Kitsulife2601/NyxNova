<Window x:Class="NovaBrowser.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:NovaBrowser.App"
        xmlns:ui="clr-namespace:NovaBrowser.App.UI"
        Title="NovaBrowser.CefSharp"
        Width="1320"
        Height="840"
        MinWidth="980"
        MinHeight="640"
        WindowStyle="None"
        ResizeMode="CanResize"
        Icon="Assets/nyxnova-icon-transparent.png"
        Background="#17181d"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged"
        PreviewKeyDown="Window_PreviewKeyDown">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="7"
                            GlassFrameThickness="0"
                            CornerRadius="12"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <local:VisibilityToBooleanConverter x:Key="VisibilityToBooleanConverter" />
        <LinearGradientBrush x:Key="ChromeTop" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#12101a" Offset="0" />
            <GradientStop Color="#171220" Offset="0.55" />
            <GradientStop Color="#0c0b12" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="ChromeBar" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#11101a" Offset="0" />
            <GradientStop Color="#17111f" Offset="0.48" />
            <GradientStop Color="#0d0c14" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="NovaText" Color="#f4eefc" />
        <SolidColorBrush x:Key="MutedText" Color="#8f869b" />
        <LinearGradientBrush x:Key="NovaButton" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#8f42ff" Offset="0" />
            <GradientStop Color="#a739ff" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="NovaFireButton" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#6f35ff" Offset="0" />
            <GradientStop Color="#b647ff" Offset="0.55" />
            <GradientStop Color="#33d6ff" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="NovaGlassPanel" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#24133f" Offset="0" />
            <GradientStop Color="#15101f" Offset="0.58" />
            <GradientStop Color="#09070d" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="NovaFlameWash" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#28105a" Offset="0" />
            <GradientStop Color="#33165f" Offset="0.48" />
            <GradientStop Color="#08070c" Offset="1" />
        </LinearGradientBrush>
        <RadialGradientBrush x:Key="NovaAuroraBackground" Center="0.62,0.18" GradientOrigin="0.62,0.18" RadiusX="0.9" RadiusY="0.9">
            <GradientStop Color="#2f1552" Offset="0" />
            <GradientStop Color="#14101f" Offset="0.42" />
            <GradientStop Color="#07080d" Offset="1" />
        </RadialGradientBrush>
        <LinearGradientBrush x:Key="AddressGlowBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#15111f" Offset="0" />
            <GradientStop Color="#0e0d15" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="NovaToolbarButtonIdle" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#252633" Offset="0" />
            <GradientStop Color="#1f202b" Offset="0.58" />
            <GradientStop Color="#191a22" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="NovaToolbarButtonHover" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#2d2a3a" Offset="0" />
            <GradientStop Color="#272130" Offset="0.58" />
            <GradientStop Color="#20212b" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="NovaToolbarButtonPressed" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#352846" Offset="0" />
            <GradientStop Color="#292235" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#d46bff" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent" SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="IconPresenter" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#ff4dff" />
                                <Setter TargetName="IconPresenter" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#c44dff" Opacity="0.65" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Foreground" Value="#ffffff" />
                                <Setter TargetName="IconPresenter" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.92" ScaleY="0.92" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DownloadPopupIconButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Background" Value="#261931" />
            <Setter Property="BorderBrush" Value="#6f43a2" />
            <Setter Property="Foreground" Value="#f8f3ff" />
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style x:Key="NovaDownloadProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="8" />
            <Setter Property="Foreground" Value="{StaticResource NovaButton}" />
            <Setter Property="Background" Value="#1a1027" />
            <Setter Property="BorderBrush" Value="#4d2a6f" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid ClipToBounds="True">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5" />
                            <Decorator x:Name="PART_Indicator" HorizontalAlignment="Left">
                                <Border CornerRadius="5" Background="{StaticResource NovaButton}">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#b967ff" Opacity="0.55" />
                                    </Border.Effect>
                                </Border>
                            </Decorator>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NovaActionButton" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Foreground" Value="#ffffff" />
            <Setter Property="Background" Value="{StaticResource NovaButton}" />
            <Setter Property="BorderBrush" Value="#c58cff" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="18" ShadowDepth="0" Color="#b967ff" Opacity="0.48" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.86" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AddressEngineComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#f3ecff" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="13,9" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemRoot" Background="{TemplateBinding Background}" CornerRadius="10" Margin="4,2" SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#31204f" />
                                <Setter Property="Foreground" Value="#ffffff" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#251842" />
                                <Setter Property="Foreground" Value="#ffffff" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AddressEngineComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="112" />
            <Setter Property="Foreground" Value="#f3ecff" />
            <Setter Property="Background" Value="#17111e" />
            <Setter Property="BorderBrush" Value="#4a314f" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource AddressEngineComboBoxItem}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="Toggle"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderBrush="Transparent">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <Border x:Name="ChipRoot" CornerRadius="15" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" SnapsToDevicePixels="True">
                                    <DockPanel Margin="11,0,8,0">
                                        <TextBlock DockPanel.Dock="Right" Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" Foreground="#c08cff" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0" />
                                        <TextBlock Text="{Binding SelectedItem.Content, RelativeSource={RelativeSource TemplatedParent}}"
                                                   Foreground="{TemplateBinding Foreground}"
                                                   FontFamily="{TemplateBinding FontFamily}"
                                                   FontSize="{TemplateBinding FontSize}"
                                                   FontWeight="{TemplateBinding FontWeight}"
                                                   VerticalAlignment="Center" />
                                    </DockPanel>
                                </Border>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=Toggle}"
                                   VerticalOffset="8"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{TemplateBinding ActualWidth}" Background="#f0120d1f" BorderBrush="#b967ff" BorderThickness="1" CornerRadius="10" Padding="5">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="22" ShadowDepth="0" Color="#a855ff" Opacity="0.42" />
                                    </Border.Effect>
                                    <ScrollViewer MaxHeight="190" Background="Transparent">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChipRoot" Property="BorderBrush" Value="#b967ff" />
                                <Setter TargetName="ChipRoot" Property="Background" Value="#21182f" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                 <Setter TargetName="ChipRoot" Property="Background" Value="#21182f" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AddressTextBox" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource NovaText}" />
            <Setter Property="CaretBrush" Value="#c08cff" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="18,0,12,1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Width" Value="Auto" />
            <Setter Property="Height" Value="34" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Margin" Value="4,2" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style x:Key="InternalButton" TargetType="Button" BasedOn="{StaticResource MenuButton}">
            <Setter Property="Background" Value="#241b32" />
            <Setter Property="BorderBrush" Value="#4c2b75" />
            <Setter Property="Foreground" Value="{StaticResource NovaText}" />
        </Style>
        <Style x:Key="NovaCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource NovaGlassPanel}" />
            <Setter Property="BorderBrush" Value="#b967ff" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,18,18" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#a24cff" Opacity="0.22" />
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="InstallAddonButton" TargetType="Button" BasedOn="{StaticResource MenuButton}">
            <Setter Property="Content" Value="Installieren" />
            <Setter Property="Background" Value="{StaticResource NovaFireButton}" />
            <Setter Property="BorderBrush" Value="#c08cff" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Installed}" Value="True">
                    <Setter Property="Content" Value="Installiert" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="NovaChipButton" TargetType="Button" BasedOn="{StaticResource MenuButton}">
            <Setter Property="Background" Value="#251226" />
            <Setter Property="BorderBrush" Value="#b967ff" />
            <Setter Property="Foreground" Value="#ead8ff" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="0,0,8,8" />
        </Style>
        <Style x:Key="QuickLinkButton" TargetType="Button" BasedOn="{StaticResource InternalButton}">
            <Setter Property="Height" Value="92" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="Background" Value="#1a1524" />
            <Setter Property="BorderBrush" Value="#47305f" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style x:Key="PinnedAddonButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#251a33" />
            <Setter Property="BorderBrush" Value="#68448f" />
        </Style>
        <Style x:Key="CaptionButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#d9b7ff" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="13"
                                Background="#00130d1c"
                                BorderBrush="#00281740"
                                BorderThickness="1"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter x:Name="IconPresenter"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#241635" Duration="0:0:0.14" />
                                            <ColorAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#724da6" Duration="0:0:0.14" />
                                            <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.14" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#00130d1c" Duration="0:0:0.18" />
                                            <ColorAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#00281740" Duration="0:0:0.18" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter Property="Foreground" Value="#ffffff" />
                                <Setter TargetName="IconPresenter" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#b967ff" Opacity="0.42" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Foreground" Value="#ffffff" />
                                <Setter TargetName="Root" Property="Background" Value="#32204a" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#b967ff" />
                                <Setter TargetName="Root" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.9" ScaleY="0.9" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CloseCaptionButton" TargetType="Button" BasedOn="{StaticResource CaptionButton}">
            <Setter Property="Foreground" Value="#ead8ff" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="13"
                                Background="#00130d1c"
                                BorderBrush="#00281740"
                                BorderThickness="1"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#5c1226" Duration="0:0:0.12" />
                                            <ColorAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#ff4f7b" Duration="0:0:0.12" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#00130d1c" Duration="0:0:0.18" />
                                            <ColorAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#00281740" Duration="0:0:0.18" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter Property="Foreground" Value="#ffffff" />
                                <Setter TargetName="Root" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#ff2e67" Opacity="0.42" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#7b1733" />
                                <Setter TargetName="Root" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.9" ScaleY="0.9" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="WindowFrame"
            Background="#0b0911"
            BorderThickness="0"
            CornerRadius="12"
            RenderTransformOrigin="0.5,0.5"
            PreviewMouseDown="RootGrid_PreviewMouseDown">
    <Border.RenderTransform>
        <ScaleTransform ScaleX="1" ScaleY="1" />
    </Border.RenderTransform>
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TitleBarRow" Height="40" />
            <RowDefinition x:Name="ToolbarRow" Height="42" />
            <RowDefinition x:Name="BookmarkRow" Height="0" />
            <RowDefinition x:Name="ContentRow" Height="*" />
            <RowDefinition x:Name="StatusRow" Height="0" />
        </Grid.RowDefinitions>

        <Grid x:Name="TitleBar" Grid.Row="0" Background="{StaticResource ChromeTop}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="142" />
            </Grid.ColumnDefinitions>

            <Border Width="36"
                    Height="36"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    MouseLeftButtonDown="WindowDragArea_MouseLeftButtonDown">
                <Image Source="Assets/nyxnova-icon-transparent.png"
                       Width="30"
                       Height="30"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality" />
            </Border>

            <ScrollViewer x:Name="TabsScrollViewer" Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" VerticalAlignment="Stretch">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <ItemsControl ItemsSource="{Binding Tabs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="AnimatedTabRoot"
                                        Width="196"
                                        Height="34"
                                        Margin="3,3,0,0"
                                        Opacity="0"
                                        CornerRadius="4"
                                        BorderBrush="#2a2433"
                                        BorderThickness="1"
                                        MouseLeftButtonDown="Tab_MouseLeftButtonDown"
                                        MouseMove="Tab_MouseMove"
                                        AllowDrop="True"
                                        DragOver="Tab_DragOver"
                                        Drop="Tab_Drop"
                                        Tag="{Binding}">
                                    <Border.RenderTransform>
                                        <TranslateTransform Y="-9" />
                                    </Border.RenderTransform>
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="AnimatedTabRoot"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     From="0"
                                                                     To="1"
                                                                     Duration="0:0:0.20">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetName="AnimatedTabRoot"
                                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                     From="-9"
                                                                     To="0"
                                                                     Duration="0:0:0.24">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#171620" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="#2a1428" />
                                                    <Setter Property="BorderBrush" Value="#b967ff" />
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect BlurRadius="14" ShadowDepth="0" Color="#a855ff" Opacity="0.38" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <DockPanel LastChildFill="True">
                                        <Button DockPanel.Dock="Right" Content="&#xE711;" Width="26" Height="26" Margin="0,4,5,4" Style="{StaticResource ToolbarButton}" Click="CloseTabButton_Click" Tag="{Binding}" />
                                        <Border DockPanel.Dock="Left" Width="20" Height="20" CornerRadius="3" Margin="9,7,8,7" Background="#100d18" BorderBrush="#b967ff" BorderThickness="1">
                                            <TextBlock Text="{Binding FaviconText}" Foreground="#f2e8ff" FontSize="10" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="{Binding Title}" Foreground="{StaticResource NovaText}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button x:Name="NewTabButton" Content="&#xE710;" Width="32" Height="32" Margin="8,4,10,4" Style="{StaticResource ToolbarButton}" Click="NewTab_Click" ToolTip="Neuer Tab" />
                    </StackPanel>
                    <Border MinWidth="160"
                            Background="Transparent"
                            MouseLeftButtonDown="WindowDragArea_MouseLeftButtonDown" />
                </DockPanel>
            </ScrollViewer>

            <StackPanel x:Name="WindowButtonsPanel" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                <Button Content="&#xE921;" Style="{StaticResource CaptionButton}" Click="MinimizeWindow_Click" ToolTip="Minimieren" />
                <Button x:Name="MaximizeButton" Content="&#xE922;" Style="{StaticResource CaptionButton}" Click="MaximizeWindow_Click" ToolTip="Maximieren" />
                <Button Content="&#xE711;" Style="{StaticResource CloseCaptionButton}" Click="CloseWindow_Click" ToolTip="Schliessen" />
            </StackPanel>
        </Grid>

        <Grid x:Name="ToolbarBar" Grid.Row="1" Background="{StaticResource ChromeBar}" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="50,0,8,0">
                <Button Content="&#xE72B;" FontSize="20" Style="{StaticResource ToolbarButton}" Click="Back_Click" ToolTip="Zurueck" />
                <Button Content="&#xE72A;" FontSize="20" Style="{StaticResource ToolbarButton}" Click="Forward_Click" ToolTip="Vorwaerts" />
                <Button x:Name="ReloadButton" Content="&#xE72C;" FontSize="19" Style="{StaticResource ToolbarButton}" Click="Reload_Click" ToolTip="Neu laden" RenderTransformOrigin="0.5,0.5">
                    <Button.RenderTransform>
                        <RotateTransform x:Name="ReloadButtonSpin" Angle="0" />
                    </Button.RenderTransform>
                </Button>
                <Button Content="&#xE80F;" FontSize="19" Style="{StaticResource ToolbarButton}" Click="Home_Click" ToolTip="Startseite" />
            </StackPanel>

            <Border x:Name="AddressBarShell" Grid.Column="1" Height="34" CornerRadius="4" Background="{StaticResource AddressGlowBrush}" BorderBrush="#2d2434" BorderThickness="1" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="0" Color="#8f42ff" Opacity="0.22" />
                </Border.Effect>
                <Grid Margin="9,0,6,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="122" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="38" />
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="SearchEngineBox" Grid.Column="0" Style="{StaticResource AddressEngineComboBox}" VerticalAlignment="Center" SelectionChanged="SearchEngineBox_SelectionChanged">
                        <ComboBoxItem Content="Google" />
                        <ComboBoxItem Content="DuckDuckGo" />
                        <ComboBoxItem Content="Bing" />
                    </ComboBox>
                    <TextBox x:Name="AddressBox" Grid.Column="1" Style="{StaticResource AddressTextBox}" KeyDown="AddressBox_KeyDown" TextChanged="AddressBox_TextChanged" GotKeyboardFocus="AddressBox_GotKeyboardFocus" ToolTip="Suche oder URL eingeben" />
                    <Button Grid.Column="2" Content="&#xE72A;" Width="28" Height="28" Background="#1b112a" BorderBrush="#b967ff" Foreground="#c08cff" FontSize="15" FontWeight="Black" Style="{StaticResource ToolbarButton}" Click="Go_Click" ToolTip="Los" />
                </Grid>
            </Border>

            <Popup x:Name="OmniboxPopupHost"
                   Grid.Column="1"
                   PlacementTarget="{Binding ElementName=AddressBarShell}"
                   Placement="Bottom"
                   VerticalOffset="8"
                   AllowsTransparency="True"
                   StaysOpen="False">
                <Border x:Name="OmniboxPopup"
                        Width="{Binding ActualWidth, ElementName=AddressBarShell}"
                        MaxHeight="420"
                        Background="#f2181127"
                        BorderBrush="#b967ff"
                        BorderThickness="1.2"
                        CornerRadius="18"
                        Padding="8"
                        Visibility="Collapsed">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="#9f4dff" Opacity="0.50" />
                    </Border.Effect>
                    <ListBox x:Name="OmniboxSuggestionsList"
                             ItemsSource="{Binding OmniboxSuggestions}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{StaticResource NovaText}"
                             MouseDoubleClick="OmniboxSuggestionsList_MouseDoubleClick"
                             SelectionChanged="OmniboxSuggestionsList_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,2" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="Transparent" />
                                <EventSetter Event="PreviewMouseLeftButtonUp" Handler="OmniboxSuggestion_Click" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemHost" CornerRadius="12" Background="{TemplateBinding Background}">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemHost" Property="Background" Value="#2a1a3d" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemHost" Property="Background" Value="#3a1f56" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="44" Margin="8,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="26" Height="26" CornerRadius="13" Background="#251736" BorderBrush="#895ac1" BorderThickness="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" Foreground="#e8d7ff" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" Foreground="{StaticResource NovaText}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource MutedText}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding Badge}" Foreground="#cda8ff" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Margin="12,0,4,0" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Popup>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,12,0">
                <Button x:Name="ExtensionsButton" Content="&#xECAA;" Width="38" Style="{StaticResource ToolbarButton}" Click="ExtensionsButton_Click" ToolTip="Erweiterungen" />
                <ItemsControl ItemsSource="{Binding PinnedExtensions}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Icon}" Width="38" Height="38" Margin="3,0" Style="{StaticResource PinnedAddonButton}" Click="PinnedExtension_Click" Tag="{Binding}" ToolTip="{Binding Name}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Grid x:Name="BookmarkButtonShell" Width="44" Height="44" Margin="1,0" Background="Transparent" PreviewMouseLeftButtonDown="BookmarkButtonShell_PreviewMouseLeftButtonDown">
                    <Button x:Name="BookmarkButton" Content="&#xE734;" Width="38" Style="{StaticResource ToolbarButton}" Click="Bookmark_Click" ToolTip="Lesezeichen" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>
                <Grid x:Name="DownloadButtonShell" Width="44" Height="44" Margin="1,0" Background="Transparent" PreviewMouseLeftButtonDown="DownloadButtonShell_PreviewMouseLeftButtonDown">
                    <Ellipse x:Name="DownloadPulse" Width="42" Height="42" Stroke="#bf77ff" StrokeThickness="1.8" Opacity="0" IsHitTestVisible="False" RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <ScaleTransform x:Name="DownloadPulseScale" ScaleX="0.78" ScaleY="0.78" />
                        </Ellipse.RenderTransform>
                        <Ellipse.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#b967ff" Opacity="0.85" />
                        </Ellipse.Effect>
                    </Ellipse>
                    <Button x:Name="DownloadsButton" Content="&#xE896;" Width="38" Style="{StaticResource ToolbarButton}" Click="DownloadsPopup_Click" ToolTip="Downloads" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Border x:Name="DownloadActiveDot" Width="8" Height="8" CornerRadius="4" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,6,5,0" Background="#d86cff" Visibility="Collapsed" IsHitTestVisible="False">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#d86cff" Opacity="0.9" />
                        </Border.Effect>
                    </Border>
                </Grid>
                <Button x:Name="MainMenuButton" Content="&#xE712;" Width="38" Style="{StaticResource ToolbarButton}" Click="Menu_Click" ToolTip="Menue" />
            </StackPanel>

            <Border x:Name="PageLoadingGlow"
                    Grid.ColumnSpan="3"
                    Height="3"
                    VerticalAlignment="Bottom"
                    Visibility="Collapsed"
                    Opacity="0"
                    RenderTransformOrigin="0,0.5"
                    IsHitTestVisible="False">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="PageLoadingScale" ScaleX="0.05" ScaleY="1" />
                </Border.RenderTransform>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#00b7ff" Offset="0" />
                        <GradientStop Color="#b967ff" Offset="0.5" />
                        <GradientStop Color="#d86cff" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="0" Color="#b967ff" Opacity="0.9" />
                </Border.Effect>
            </Border>
        </Grid>

        <Border x:Name="BookmarkBar" Grid.Row="2" Background="#1f2026" BorderBrush="#30313a" BorderThickness="0,1,0,1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Bookmarks}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Title}" Tag="{Binding}" Style="{StaticResource MenuButton}" Click="BookmarkBar_Click" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="3" Background="#0b0911" ClipToBounds="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="48" />
                <ColumnDefinition x:Name="BrowserColumn" Width="*" />
            </Grid.ColumnDefinitions>
            <Border x:Name="SidebarPlaceholder"
                    Grid.Column="0"
                    Background="#0d0a13"
                    BorderBrush="#22182a"
                    BorderThickness="0,0,1,0"
                    Visibility="Visible"
                    Panel.ZIndex="60"
                    ClipToBounds="True">
                <Grid>
                    <StackPanel VerticalAlignment="Top" Margin="0,18,0,0">
                        <Button Content="&#xE80F;" Style="{StaticResource ToolbarButton}" Click="Home_Click" ToolTip="Startseite" />
                        <Button Content="&#xE81C;" Style="{StaticResource ToolbarButton}" Click="History_Click" ToolTip="Verlauf" Margin="2,10,2,0" />
                        <Button Content="&#xE81E;" Style="{StaticResource ToolbarButton}" Click="Downloads_Click" ToolTip="Downloads" Margin="2,10,2,0" />
                        <Button Content="&#xE734;" Style="{StaticResource ToolbarButton}" Click="Bookmark_Click" ToolTip="Lesezeichen" Margin="2,10,2,0" />
                        <Button Content="&#xECAA;" Style="{StaticResource ToolbarButton}" Click="OpenExtensionsPage_Click" ToolTip="Addons" Margin="2,10,2,0" />
                        <Button Content="&#xE713;" Style="{StaticResource ToolbarButton}" Click="Settings_Click" ToolTip="Einstellungen" Margin="2,10,2,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="HistorySidePanel"
                    Grid.Column="1"
                    Width="410"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch"
                    Margin="0,0,0,0"
                    Background="#f4070610"
                    BorderBrush="#35214d"
                    BorderThickness="0,0,1,0"
                    Visibility="Collapsed"
                    Panel.ZIndex="30">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="36" ShadowDepth="0" Color="#8f42ff" Opacity="0.34" />
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="4" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="18,18,16,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,18">
                            <Button DockPanel.Dock="Right"
                                    Content="&#xE711;"
                                    Width="32"
                                    Height="32"
                                    Style="{StaticResource ToolbarButton}"
                                    Click="CloseHistorySidePanel_Click"
                                    ToolTip="Verlauf schliessen" />
                            <TextBlock Text="VERLAUF"
                                       Foreground="#f2eaff"
                                       FontSize="17"
                                       FontWeight="Black"
                                       VerticalAlignment="Center" />
                        </DockPanel>

                        <Grid Grid.Row="1" Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="42" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Height="38"
                                    Background="#c70c0a14"
                                    BorderBrush="#4d326d"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <DockPanel Margin="12,0">
                                    <TextBlock Text="&#xE721;"
                                               FontFamily="Segoe MDL2 Assets"
                                               Foreground="#bfa9da"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <TextBox x:Name="SideHistorySearchBox"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Foreground="#f2eaff"
                                             CaretBrush="#c08cff"
                                             SelectionBrush="#8f42ff"
                                             FontSize="13"
                                             VerticalContentAlignment="Center"
                                             Text="Verlauf durchsuchen"
                                             GotFocus="SideHistorySearchBox_GotFocus"
                                             KeyUp="SideHistorySearchBox_KeyUp" />
                                </DockPanel>
                            </Border>
                            <Button Grid.Column="1"
                                    Content="&#xE72C;"
                                    Style="{StaticResource ToolbarButton}"
                                    Click="ClearHistory_Click"
                                    ToolTip="Verlauf loeschen"
                                    Margin="8,0,0,0" />
                        </Grid>

                        <ListBox x:Name="SideHistoryListBox"
                                 Grid.Row="2"
                                 ItemsSource="{Binding History}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource NovaText}"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 MouseDoubleClick="SideHistoryList_DoubleClick">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,6" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="ItemRoot"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="13"
                                                        Padding="9,8">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemRoot" Property="Background" Value="#241533" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="ItemRoot" Property="Background" Value="#321c4d" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding VisitedAt, StringFormat={}{0:HH:mm}}"
                                                   Foreground="#c08cff"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Top" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="#fff8ff"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Url}"
                                                       Foreground="#9d91ad"
                                                       FontSize="12"
                                                       Margin="0,3,0,0"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Grid.Row="3"
                                Content="Vollstaendige Verlaufsansicht oeffnen"
                                Style="{StaticResource NovaActionButton}"
                                Height="42"
                                Margin="0,14,0,12"
                                Click="OpenFullHistory_Click" />
                    </Grid>

                    <Border Grid.Column="1"
                            Width="4"
                            HorizontalAlignment="Right"
                            CornerRadius="3"
                            Opacity="0.78">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop x:Name="HistoryEdgeA" Color="#00d9ff" Offset="-0.25" />
                                <GradientStop x:Name="HistoryEdgeB" Color="#c08cff" Offset="0.1" />
                                <GradientStop x:Name="HistoryEdgeC" Color="#00000000" Offset="0.42" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Color="#b967ff" Opacity="0.82" />
                        </Border.Effect>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="HistoryEdgeA" Storyboard.TargetProperty="Offset" From="-0.35" To="0.78" Duration="0:0:3.8" />
                                        <DoubleAnimation Storyboard.TargetName="HistoryEdgeB" Storyboard.TargetProperty="Offset" From="-0.08" To="1.05" Duration="0:0:3.8" />
                                        <DoubleAnimation Storyboard.TargetName="HistoryEdgeC" Storyboard.TargetProperty="Offset" From="0.24" To="1.28" Duration="0:0:3.8" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                    </Border>
                </Grid>
            </Border>

            <ContentControl x:Name="BrowserHost" Grid.Column="1" Panel.ZIndex="0" ClipToBounds="True" Background="#0b0911" />

            <Border x:Name="FindBar"
                    Grid.Column="1"
                    Width="420"
                    Height="46"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,16,22,0"
                    Background="#ee15101f"
                    BorderBrush="#a968ff"
                    BorderThickness="1"
                    CornerRadius="23"
                    Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="22" ShadowDepth="0" Color="#a968ff" Opacity="0.34" />
                </Border.Effect>
                <Grid Margin="14,0,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="36" />
                        <ColumnDefinition Width="36" />
                        <ColumnDefinition Width="36" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="FindBox"
                             Grid.Column="0"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{StaticResource NovaText}"
                             CaretBrush="#f3ecff"
                             FontSize="14"
                             FontWeight="SemiBold"
                             VerticalContentAlignment="Center"
                             KeyDown="FindBox_KeyDown"
                             TextChanged="FindBox_TextChanged"
                             ToolTip="In Seite suchen" />
                    <Button Grid.Column="1" Content="&#xE70E;" Style="{StaticResource ToolbarButton}" Width="32" Height="32" Click="FindPrevious_Click" ToolTip="Vorheriger Treffer" />
                    <Button Grid.Column="2" Content="&#xE70D;" Style="{StaticResource ToolbarButton}" Width="32" Height="32" Click="FindNext_Click" ToolTip="Naechster Treffer" />
                    <Button Grid.Column="3" Content="&#xE711;" Style="{StaticResource ToolbarButton}" Width="32" Height="32" Click="CloseFindBar_Click" ToolTip="Schliessen" />
                </Grid>
            </Border>

            <Grid x:Name="InternalHost" Grid.Column="1" Visibility="Collapsed" Background="{StaticResource NovaAuroraBackground}">
                <Grid IsHitTestVisible="False" Opacity="0.78">
                    <Ellipse Width="560" Height="360" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-120,-120,0" Fill="#402088">
                        <Ellipse.Effect>
                            <BlurEffect Radius="70" />
                        </Ellipse.Effect>
                    </Ellipse>
                    <Ellipse Width="360" Height="280" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-110,0,0,-80" Fill="#46122f">
                        <Ellipse.Effect>
                            <BlurEffect Radius="72" />
                        </Ellipse.Effect>
                    </Ellipse>
                    <Ellipse Width="220" Height="220" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,80,0,0" Fill="#26325f" Opacity="0.45">
                        <Ellipse.Effect>
                            <BlurEffect Radius="80" />
                        </Ellipse.Effect>
                    </Ellipse>
                </Grid>

                <Grid x:Name="StartPage" Visibility="Collapsed" Margin="72,48">
                    <StackPanel Width="980" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Width="96" Height="96" CornerRadius="30" HorizontalAlignment="Center" Background="{StaticResource NovaButton}" BorderBrush="#d9b8ff" BorderThickness="1">
                            <TextBlock Text="N" Foreground="White" FontSize="54" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#ffffff" Opacity="0.3" />
                                </TextBlock.Effect>
                            </TextBlock>
                        </Border>
