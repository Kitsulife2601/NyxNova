                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                            <Border Style="{StaticResource NovaCard}" Width="800">
                                <StackPanel>
                                    <TextBlock Text="HTML5 Video Support" Foreground="{StaticResource NovaText}" FontSize="18" FontWeight="Black" />
                                    <TextBlock x:Name="MediaSummaryText" Text="Noch nicht getestet." Foreground="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,10,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource NovaCard}" Width="800">
                                <StackPanel>
                                    <TextBlock Text="Codec-Ergebnisse" Foreground="{StaticResource NovaText}" FontSize="18" FontWeight="Black" />
                                    <TextBlock x:Name="MediaCodecRowsText" Text="Noch nicht getestet." Foreground="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,10,0,0" FontFamily="Consolas" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource NovaCard}" Width="800">
                                <StackPanel>
                                    <TextBlock Text="Tabelle" Foreground="{StaticResource NovaText}" FontSize="18" FontWeight="Black" />
                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="2*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Feature" Foreground="{StaticResource NovaText}" FontWeight="Bold" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Ergebnis" Foreground="{StaticResource NovaText}" FontWeight="Bold" />
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Bewertung" Foreground="{StaticResource NovaText}" FontWeight="Bold" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="MP4" Foreground="{StaticResource MutedText}" Margin="0,8,0,0" />
