                            Visibility="Collapsed"
                            NewTabRequested="MainMenu_NewTabRequested"
                            NewWindowRequested="MainMenu_NewWindowRequested"
                            IncognitoRequested="MainMenu_IncognitoRequested"
                            ProfileRequested="MainMenu_ProfileRequested"
                            PasswordsRequested="MainMenu_PasswordsRequested"
                            HistoryRequested="MainMenu_HistoryRequested"
                            DownloadsRequested="MainMenu_DownloadsRequested"
                            BookmarksRequested="MainMenu_BookmarksRequested"
                            TabGroupsRequested="MainMenu_TabGroupsRequested"
                            ExtensionsRequested="MainMenu_ExtensionsRequested"
                            ClearDataRequested="MainMenu_ClearDataRequested"
                            ZoomOutRequested="MainMenu_ZoomOutRequested"
                            ZoomInRequested="MainMenu_ZoomInRequested"
                            FullscreenRequested="MainMenu_FullscreenRequested"
                            PrintRequested="MainMenu_PrintRequested"
                            LensRequested="MainMenu_LensRequested"
                            TranslateRequested="MainMenu_TranslateRequested"
                            FindEditRequested="MainMenu_FindEditRequested"
                            ShareRequested="MainMenu_ShareRequested"
                            MoreToolsRequested="MainMenu_MoreToolsRequested"
                            StoreRequested="MainMenu_StoreRequested"
                            DevToolsRequested="MainMenu_DevToolsRequested"
                            DiagnosticsRequested="MainMenu_DiagnosticsRequested"
                            MediaDiagnosticsRequested="MainMenu_MediaDiagnosticsRequested"
                            SavePageRequested="MainMenu_SavePageRequested"
                            CopyLinkRequested="MainMenu_CopyLinkRequested"
                            HelpRequested="MainMenu_HelpRequested"
                            SettingsRequested="MainMenu_SettingsRequested"
                            ExitRequested="MainMenu_ExitRequested" />
        </Popup>

        <Grid x:Name="PageLoadingOverlay"
              Grid.Row="3"
              Panel.ZIndex="18"
              Margin="48,0,0,0"
              Visibility="Collapsed"
              Opacity="0"
              IsHitTestVisible="False">
            <Border Width="230"
                    Height="230"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#cc07050c"
                    BorderBrush="#412030"
                    BorderThickness="1"
                    CornerRadius="18">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="42" ShadowDepth="0" Color="#a855ff" Opacity="0.36" />
                </Border.Effect>
            </Border>

            <Grid Width="176"
                  Height="176"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <RotateTransform x:Name="PageLoadingRingRotate" Angle="0" />
                </Grid.RenderTransform>
                <Ellipse Width="176" Height="176" Stroke="#2d1a2a" StrokeThickness="11" Opacity="0.9" />
                <Ellipse Width="176" Height="176" Stroke="#ffffff" StrokeThickness="13" StrokeDashArray="7 4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Opacity="0.96" />
                <Ellipse Width="150" Height="150" Stroke="#8f42ff" StrokeThickness="6" StrokeDashArray="4 7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Opacity="0.95" />
                <Ellipse Width="128" Height="128" Stroke="#27e7ff" StrokeThickness="5" StrokeDashArray="8 10" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Opacity="0.9" />
            </Grid>

            <Grid Width="104"
                  Height="104"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <ScaleTransform x:Name="PageLoadingLogoScale" ScaleX="1" ScaleY="1" />
                </Grid.RenderTransform>
                <Ellipse Fill="#dd10081f" Stroke="#b967ff" StrokeThickness="1.3">
                    <Ellipse.Effect>
                        <DropShadowEffect BlurRadius="24" ShadowDepth="0" Color="#a855ff" Opacity="0.45" />
                    </Ellipse.Effect>
                </Ellipse>
                <Image Source="Assets/nyxnova-icon-transparent.png" Width="88" Height="88" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" ClipToBounds="True" />
            </Grid>

            <TextBlock Text="NyxNova laedt..."
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,186,0,0"
                       Foreground="#f7edf4"
                       FontSize="13"
                       FontWeight="Bold"
                       Opacity="0.88" />
        </Grid>

        <Border x:Name="SlowLoadBar"
                Grid.Row="3"
                Panel.ZIndex="19"
                Width="820"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="64,0,22,22"
                Background="#ee17121f"
                BorderBrush="#a968ff"
                BorderThickness="1"
                CornerRadius="16"
                Padding="14,10"
                Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect BlurRadius="22" ShadowDepth="0" Color="#a968ff" Opacity="0.28" />
            </Border.Effect>
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="14,0,0,0">
                    <Button Content="Neu laden" Style="{StaticResource InternalButton}" Click="ReloadSlowPage_Click" Margin="0,0,8,0" />
                    <Button Content="Ohne Schutz laden" Style="{StaticResource InternalButton}" Click="DisableProtectionForPage_Click" />
                    <Button Content="Cookies loeschen" Style="{StaticResource InternalButton}" Margin="8,0,0,0" Click="ClearCookiesForPage_Click" />
                    <Button Content="DevTools" Style="{StaticResource InternalButton}" Margin="8,0,0,0" Click="OpenDevTools_Click" />
                    <Button Content="Diagnose" Style="{StaticResource InternalButton}" Margin="8,0,0,0" Click="OpenDiagnostics_Click" />
                    <Button Content="Media" Style="{StaticResource InternalButton}" Margin="8,0,0,0" Click="OpenMediaDiagnostics_Click" />
                </StackPanel>
                <TextBlock x:Name="SlowLoadText"
                           Text="Diese Seite laedt ungewoehnlich lange. Pruefe Cookies, Tracker-Blocker oder Popups."
                           Foreground="{StaticResource NovaText}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />
            </DockPanel>
        </Border>

        <ContentControl x:Name="MediaProbeHost"
                        Grid.Row="3"
                        Width="1"
                        Height="1"
                        Opacity="0"
                        IsHitTestVisible="False"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top" />

        <Border x:Name="StatusBar" Grid.Row="4" Background="#202124" BorderBrush="#34313d" BorderThickness="0,1,0,0" Visibility="Collapsed">
            <TextBlock x:Name="StatusText" Text="Bereit" Foreground="{StaticResource MutedText}" VerticalAlignment="Center" Padding="14,0" FontSize="12" />
        </Border>
    </Grid>
    </Border>
</Window>
