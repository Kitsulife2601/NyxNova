                                        <TextBlock x:Name="MediaTableH264Result" Grid.Row="2" Grid.Column="1" Text="-" Foreground="{StaticResource MutedText}" Margin="0,8,0,0" />
                                        <TextBlock x:Name="MediaTableH264Rating" Grid.Row="2" Grid.Column="2" Text="-" Foreground="{StaticResource MutedText}" Margin="0,8,0,0" />
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="AAC" Foreground="{StaticResource MutedText}" Margin="0,8,0,0" />
                                        <TextBlock x:Name="MediaTableAacResult" Grid.Row="3" Grid.Column="1" Text="-" Foreground="{StaticResource MutedText}" Margin="0,8,0,0" />
                                        <TextBlock x:Name="MediaTableAacRating" Grid.Row="3" Grid.Column="2" Text="-" Foreground="{StaticResource MutedText}" Margin="0,8,0,0" />
                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="WebM" Foreground="{StaticResource MutedText}" Margin="0,8,0,0" />
                                        <TextBlock x:Name="MediaTableWebmResult" Grid.Row="4" Grid.Column="1" Text="-" Foreground="{StaticResource MutedText}" Margin="0,8,0,0" />
                                        <TextBlock x:Name="MediaTableWebmRating" Grid.Row="4" Grid.Column="2" Text="-" Foreground="{StaticResource MutedText}" Margin="0,8,0,0" />
                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="MediaSource" Foreground="{StaticResource MutedText}" Margin="0,8,0,0" />
                                        <TextBlock x:Name="MediaTableMseResult" Grid.Row="5" Grid.Column="1" Text="-" Foreground="{StaticResource MutedText}" Margin="0,8,0,0" />
                                        <TextBlock x:Name="MediaTableMseRating" Grid.Row="5" Grid.Column="2" Text="-" Foreground="{StaticResource MutedText}" Margin="0,8,0,0" />
                                        <TextBlock Grid.Row="6" Grid.Column="0" Text="WebGL" Foreground="{StaticResource MutedText}" Margin="0,8,0,0" />
                                        <TextBlock x:Name="MediaTableWebglResult" Grid.Row="6" Grid.Column="1" Text="-" Foreground="{StaticResource MutedText}" Margin="0,8,0,0" />
                                        <TextBlock x:Name="MediaTableWebglRating" Grid.Row="6" Grid.Column="2" Text="-" Foreground="{StaticResource MutedText}" Margin="0,8,0,0" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource NovaCard}" Width="800">
                                <StackPanel>
                                    <TextBlock Text="HTML5 Testvideo" Foreground="{StaticResource NovaText}" FontSize="18" FontWeight="Black" />
                                    <TextBlock x:Name="MediaVideoEventText" Text="Noch nicht gestartet." Foreground="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,10,0,0" />
                                    <Button Content="Testvideo laden" Style="{StaticResource InternalButton}" Width="160" HorizontalAlignment="Left" Margin="0,12,0,0" Click="LoadTestVideo_Click" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource NovaCard}" Width="800">
                                <StackPanel>
                                    <TextBlock Text="Bewertung" Foreground="{StaticResource NovaText}" FontSize="18" FontWeight="Black" />
                                    <TextBlock x:Name="MediaVerdictText" Text="Noch nicht getestet." Foreground="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,10,0,0" />
                                </StackPanel>
                            </Border>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Media-Test neu ausfuehren" Style="{StaticResource InternalButton}" Margin="0,0,8,0" Click="RunMediaDiagnostics_Click" />
                                <Button Content="Allgemeine Diagnose oeffnen" Style="{StaticResource InternalButton}" Click="OpenDiagnostics_Click" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Grid x:Name="SettingsPage" Visibility="Collapsed" Margin="80,42">
                    <StackPanel Width="620">
                        <TextBlock Text="Settings" Foreground="{StaticResource NovaText}" FontSize="32" FontWeight="Black" Margin="0,0,0,24" />
                        <TextBlock Text="Search engine" Foreground="{StaticResource MutedText}" FontWeight="Bold" />
                        <ComboBox x:Name="SettingsSearchEngineBox" Height="36" Margin="0,8,0,22" SelectionChanged="SettingsSearchEngineBox_SelectionChanged">
                            <ComboBoxItem Content="Google" />
                            <ComboBoxItem Content="DuckDuckGo" />
                            <ComboBoxItem Content="Bing" />
                        </ComboBox>
                        <CheckBox x:Name="BookmarkBarCheckBox" Content="Show bookmark bar" Foreground="{StaticResource NovaText}" Margin="0,0,0,20" Checked="BookmarkBarCheckBox_Changed" Unchecked="BookmarkBarCheckBox_Changed" />
                        <TextBlock Text="Start page" Foreground="{StaticResource NovaText}" FontSize="18" FontWeight="Black" Margin="0,14,0,6" />
                        <TextBlock Text="nova://start" Foreground="{StaticResource MutedText}" />
                        <TextBlock Text="Design" Foreground="{StaticResource NovaText}" FontSize="18" FontWeight="Black" Margin="0,20,0,6" />
                        <TextBlock Text="Nova neon dark theme" Foreground="{StaticResource MutedText}" />
                        <TextBlock Text="Downloads" Foreground="{StaticResource NovaText}" FontSize="18" FontWeight="Black" Margin="0,20,0,6" />
                        <TextBlock Text="Downloads werden im Windows-Downloads-Ordner gespeichert." Foreground="{StaticResource MutedText}" TextWrapping="Wrap" />
                        <TextBlock Text="Erweiterungen" Foreground="{StaticResource NovaText}" FontSize="18" FontWeight="Black" Margin="0,20,0,6" />
                        <Button Content="Erweiterungen verwalten" Style="{StaticResource InternalButton}" Click="OpenExtensionsPage_Click" />
                        <Button Content="NovaStore oeffnen" Style="{StaticResource InternalButton}" Margin="0,8,0,0" Click="OpenStore_Click" />
                        <TextBlock Text="Security" Foreground="{StaticResource NovaText}" FontSize="18" FontWeight="Black" Margin="0,20,0,6" />
                        <TextBlock Text="CEFSharp uses persistent cookies and cache. Web security stays enabled. Google and YouTube open inside NovaBrowser first." Foreground="{StaticResource MutedText}" TextWrapping="Wrap" />
                        <TextBlock Text="Build" Foreground="{StaticResource NovaText}" FontSize="18" FontWeight="Black" Margin="0,20,0,6" />
                        <TextBlock x:Name="BuildInfoText" Text="Build-Version wird geladen..." Foreground="{StaticResource MutedText}" TextWrapping="Wrap" />
                        <TextBlock Text="Beta Updates" Foreground="{StaticResource NovaText}" FontSize="18" FontWeight="Black" Margin="0,20,0,6" />
                        <TextBlock Text="NyxNova kann Beta-Updates im Hintergrund vorbereiten und zeigt den Fortschritt auf einer eigenen Update-Seite." Foreground="{StaticResource MutedText}" TextWrapping="Wrap" />
                        <Button Content="Update-Seite oeffnen" Style="{StaticResource InternalButton}" Margin="0,10,0,0" Click="OpenUpdatePage_Click" />
                        <Button Content="Einstellungen zuruecksetzen" Style="{StaticResource InternalButton}" Margin="0,20,0,0" Click="ResetSettings_Click" />
                    </StackPanel>
                </Grid>

                <Grid x:Name="UpdatePage" Visibility="Collapsed" Margin="80,42">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Width="760">
                            <Border Style="{StaticResource NovaCard}" Padding="28">
                                <StackPanel>
                                    <TextBlock Text="NyxNova Beta Update" Foreground="{StaticResource NovaText}" FontSize="36" FontWeight="Black" />
                                    <TextBlock Text="Updates laufen im Hintergrund. Du kannst weiter surfen, waehrend Nova das Beta-Paket vorbereitet." Foreground="{StaticResource MutedText}" FontSize="15" TextWrapping="Wrap" Margin="0,8,0,22" />
                                    <Border CornerRadius="24" Background="#241335" BorderBrush="#b967ff" BorderThickness="1.2" Padding="20">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="58" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="46" Height="46" CornerRadius="23" Background="#361456" BorderBrush="#d28cff" BorderThickness="1.2">
                                                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" Foreground="#f4e8ff" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding UpdateStatusText}" Foreground="{StaticResource NovaText}" FontSize="20" FontWeight="Black" />
                                                <TextBlock Text="{Binding UpdateDetailText}" Foreground="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,4,0,12" />
                                                <ProgressBar Minimum="0" Maximum="100" Value="{Binding UpdateProgress, Mode=OneWay}" Height="10" Style="{StaticResource NovaDownloadProgressBar}" />
                                                <TextBlock Text="{Binding UpdateProgressText}" Foreground="#dfc9ff" FontSize="12" Margin="0,8,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                                        <Button Content="{Binding UpdateActionText}" Style="{StaticResource InternalButton}" Click="StartBetaUpdate_Click" />
                                        <Button Content="Im Hintergrund laufen lassen" Style="{StaticResource InternalButton}" Margin="10,0,0,0" Click="HideUpdatePage_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Grid x:Name="ExtensionsPage" Visibility="Collapsed" Margin="80,42">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,18">
                        <TextBlock Text="Meine Nova Addons" Foreground="{StaticResource NovaText}" FontSize="36" FontWeight="Black" />
                        <TextBlock Text="Installierte Addons, Pins, Berechtigungen und Nova-Popups." Foreground="{StaticResource MutedText}" Margin="0,4,0,0" />
                            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                <TextBox x:Name="AddonSearchBox" Width="300" Height="34" VerticalContentAlignment="Center" Text="Addons suchen" GotFocus="AddonSearchBox_GotFocus" KeyUp="AddonSearchBox_KeyUp" />
                                <ComboBox x:Name="AddonFilterBox" Width="160" Height="34" Margin="12,0,0,0" SelectionChanged="AddonFilterBox_SelectionChanged">
                                    <ComboBoxItem Content="Alle" IsSelected="True" />
                                    <ComboBoxItem Content="Aktiviert" />
                                    <ComboBoxItem Content="Deaktiviert" />
                                    <ComboBoxItem Content="Angeheftet" />
                                </ComboBox>
                                <Button Content="NovaStore oeffnen" Style="{StaticResource NovaChipButton}" Margin="12,0,0,0" Click="OpenStore_Click" />
                            </StackPanel>
                        </StackPanel>
                        <ItemsControl x:Name="InstalledAddonsList" ItemsSource="{Binding InstalledAddons}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="380" Style="{StaticResource NovaCard}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource NovaText}" FontSize="17" FontWeight="Black" />
                                            <TextBlock Text="{Binding Description}" Foreground="{StaticResource MutedText}" Margin="0,8,0,10" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Version, StringFormat=Version {0}}" Foreground="{StaticResource MutedText}" />
                                            <TextBlock Text="{Binding Author, StringFormat=Autor: {0}}" Foreground="{StaticResource MutedText}" />
                                            <TextBlock Text="{Binding Category, StringFormat=Kategorie: {0}}" Foreground="{StaticResource MutedText}" />
                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                <Border CornerRadius="12" Background="#251226" BorderBrush="#ff6a2b" BorderThickness="1" Padding="9,4" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding Enabled, StringFormat=Status: {0}}" Foreground="#ffd7c2" FontWeight="Bold" />
                                                </Border>
                                                <Border CornerRadius="12" Background="#22143a" BorderBrush="#b967ff" BorderThickness="1" Padding="9,4">
                                                    <TextBlock Text="{Binding Pinned, StringFormat=Pin: {0}}" Foreground="#e7d4ff" FontWeight="Bold" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="Berechtigungen:" Foreground="{StaticResource NovaText}" FontWeight="Bold" Margin="0,12,0,4" />
                                            <ItemsControl ItemsSource="{Binding Permissions}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" Foreground="{StaticResource MutedText}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Text="Host-Zugriff:" Foreground="{StaticResource NovaText}" FontWeight="Bold" Margin="0,12,0,4" />
                                            <ItemsControl ItemsSource="{Binding HostPermissions}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" Foreground="{StaticResource MutedText}" TextTrimming="CharacterEllipsis" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                                <Button Content="..." Tag="{Binding}" Style="{StaticResource MenuButton}" Click="AddonCardMenu_Click" />
                                                <Button Content="Enable/Disable" Tag="{Binding}" Style="{StaticResource MenuButton}" Click="ToggleAddon_Click" />
                                                <Button Content="Pin" Tag="{Binding}" Style="{StaticResource MenuButton}" Click="PinAddon_Click" />
                                                <Button Content="Details" Tag="{Binding}" Style="{StaticResource MenuButton}" Click="AddonDetails_Click" />
                                                <Button Content="Remove" Tag="{Binding}" Style="{StaticResource MenuButton}" Click="RemoveAddon_Click" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Grid>

                <Grid x:Name="StorePage" Visibility="Collapsed" Margin="80,42">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,18">
                            <Border Height="170" CornerRadius="28" Background="{StaticResource NovaFlameWash}" BorderBrush="#ff6a2b" BorderThickness="1.2" Padding="26" Margin="0,0,0,18">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="260" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="NovaStore" Foreground="#ffe4d4" FontSize="46" FontWeight="Black">
                                            <TextBlock.Effect>
                                                <DropShadowEffect BlurRadius="28" ShadowDepth="0" Color="#ff5a24" Opacity="0.58" />
                                            </TextBlock.Effect>
                                        </TextBlock>
                                        <TextBlock Text="Addons fuer deinen Nova Browser" Foreground="#e7d4ff" FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0" />
                                    </StackPanel>
                                    <Border Grid.Column="1" CornerRadius="24" Background="#1b1022" BorderBrush="#b967ff" BorderThickness="1" Padding="18">
                                        <StackPanel>
                                            <TextBlock Text="Featured" Foreground="#ffb48d" FontWeight="Black" />
                                            <TextBlock Text="Theme Switcher" Foreground="{StaticResource NovaText}" FontSize="24" FontWeight="Black" Margin="0,8,0,0" />
                                            <TextBlock Text="Wechselt Nova-Farbstimmungen direkt im Browser." Foreground="{StaticResource MutedText}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="StoreSearchBox" Width="320" Height="34" VerticalContentAlignment="Center" Text="NovaStore durchsuchen" GotFocus="StoreSearchBox_GotFocus" KeyUp="StoreSearchBox_KeyUp" />
                                <ComboBox x:Name="StoreCategoryBox" Width="190" Height="34" Margin="12,0,0,0" SelectionChanged="StoreCategoryBox_SelectionChanged">
                                    <ComboBoxItem Content="Alle" IsSelected="True" />
                                    <ComboBoxItem Content="Produktivitaet" />
                                    <ComboBoxItem Content="Datenschutz" />
                                    <ComboBoxItem Content="Design" />
                                    <ComboBoxItem Content="Social" />
                                    <ComboBoxItem Content="Musik" />
                                    <ComboBoxItem Content="Entwickler" />
                                    <ComboBoxItem Content="Nova Tools" />
                                </ComboBox>
                            </StackPanel>
                            <WrapPanel Margin="0,14,0,0">
                                <Button Content="Produktivitaet" Style="{StaticResource NovaChipButton}" Tag="Produktivitaet" Click="StoreChip_Click" />
                                <Button Content="Datenschutz" Style="{StaticResource NovaChipButton}" Tag="Datenschutz" Click="StoreChip_Click" />
                                <Button Content="Design" Style="{StaticResource NovaChipButton}" Tag="Design" Click="StoreChip_Click" />
                                <Button Content="Social" Style="{StaticResource NovaChipButton}" Tag="Social" Click="StoreChip_Click" />
                                <Button Content="Musik" Style="{StaticResource NovaChipButton}" Tag="Musik" Click="StoreChip_Click" />
                                <Button Content="Entwickler" Style="{StaticResource NovaChipButton}" Tag="Entwickler" Click="StoreChip_Click" />
                                <Button Content="Nova Tools" Style="{StaticResource NovaChipButton}" Tag="Nova Tools" Click="StoreChip_Click" />
                            </WrapPanel>
                        </StackPanel>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="StoreAddonsList" ItemsSource="{Binding StoreAddons}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="330" Style="{StaticResource NovaCard}">
                                            <StackPanel>
                                                <Border Width="56" Height="56" CornerRadius="18" Background="{StaticResource NovaFireButton}" BorderBrush="#ffd7c2" BorderThickness="1" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource NovaText}" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource NovaText}" FontSize="18" FontWeight="Black" Margin="0,12,0,0" />
                                                <TextBlock Text="{Binding Description}" Foreground="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,8,0,8" />
                                                <TextBlock Text="{Binding Author, StringFormat=Autor: {0}}" Foreground="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding Version, StringFormat=Version {0}}" Foreground="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding Rating, StringFormat=Bewertung {0:0.0}/5}" Foreground="{StaticResource MutedText}" />
                                                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                                    <Button Tag="{Binding}" Style="{StaticResource InstallAddonButton}" Click="InstallAddon_Click" />
                                                    <Button Content="Details" Tag="{Binding}" Style="{StaticResource MenuButton}" Click="AddonDetails_Click" />
                                                    <Button Content="Verwalten" Tag="{Binding}" Style="{StaticResource MenuButton}" Click="ManageAddon_Click" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Grid>

