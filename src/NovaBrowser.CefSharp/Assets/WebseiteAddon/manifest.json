{
  "manifest_version": 3,
  "name": "Neuer Tab",
  "description": "Eine moderne Startseite, die automatisch im neuen Tab öffnet.",
  "version": "0.2.10",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_title": "Neuer Tab öffnen",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "chrome_url_overrides": {
    "newtab": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "webNavigation"
  ],
  "host_permissions": [
    "http://127.0.0.1:8787/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
