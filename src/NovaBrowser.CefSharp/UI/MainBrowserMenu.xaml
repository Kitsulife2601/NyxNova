<UserControl x:Class="NovaBrowser.App.UI.MainBrowserMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="332"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <LinearGradientBrush x:Key="NovaMenuPanelBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#18101f" Offset="0" />
            <GradientStop Color="#100914" Offset="0.55" />
            <GradientStop Color="#09060d" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="NovaMenuHoverBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#3a164d" Offset="0" />
            <GradientStop Color="#241130" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="NovaMenuIcon" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#ff2f88" />
            <Setter Property="Width" Value="25" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="NovaMenuText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#f8efff" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="NovaMenuHint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9f91b6" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="NovaMenuButton" TargetType="Button">
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Margin" Value="7,0" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#f8efff" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RowRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowRoot" Property="Background" Value="{StaticResource NovaMenuHoverBrush}" />
                                <Setter TargetName="RowRoot" Property="BorderBrush" Value="#8a39ff" />
                                <Setter TargetName="RowRoot" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="18" ShadowDepth="0" Color="#9f4dff" Opacity="0.35" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RowRoot" Property="Background" Value="#4b1a63" />
                                <Setter Property="Foreground" Value="#ffffff" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NovaRoundMenuButton" TargetType="Button">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="Background" Value="#211229" />
            <Setter Property="BorderBrush" Value="#6d2f9d" />
            <Setter Property="Foreground" Value="#f7d7ff" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="16"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#351640" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#ff2f88" />
                                <Setter TargetName="Root" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="14" ShadowDepth="0" Color="#ff2f88" Opacity="0.45" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource NovaMenuPanelBrush}"
            BorderBrush="#9f4dff"
            BorderThickness="1.2"
            CornerRadius="16"
            Padding="0"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="34" ShadowDepth="0" Color="#8b35ff" Opacity="0.38" />
        </Border.Effect>

        <ScrollViewer MaxHeight="560"
                      VerticalScrollBarVisibility="Disabled"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False">
            <StackPanel Margin="0,5">
                <Grid Height="28" Margin="12,0,12,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="31" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="23" Height="23" CornerRadius="11.5" Background="#271331" BorderBrush="#ff2f88" BorderThickness="1" VerticalAlignment="Center">
                        <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" Foreground="#ff2f88" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="NyxNova" Foreground="#ffffff" FontSize="13" FontWeight="Bold" />
                        <TextBlock Text="Browser-Werkzeuge" Foreground="#9f91b6" FontSize="10" />
                    </StackPanel>
                </Grid>

                <Border Height="1" Background="#30203d" Margin="10,2,10,3" />

                <Button Style="{StaticResource NovaMenuButton}" Click="NewTab_Click">
                    <DockPanel>
                        <TextBlock Text="&#xE8A7;" Style="{StaticResource NovaMenuIcon}" />
                        <TextBlock DockPanel.Dock="Right" Text="Strg+T" Style="{StaticResource NovaMenuHint}" />
                        <TextBlock Text="Neuer Tab" Style="{StaticResource NovaMenuText}" />
                    </DockPanel>
                </Button>
                <Button Style="{StaticResource NovaMenuButton}" Click="NewWindow_Click">
                    <DockPanel>
                        <TextBlock Text="&#xE8A7;" Style="{StaticResource NovaMenuIcon}" />
                        <TextBlock DockPanel.Dock="Right" Text="Strg+N" Style="{StaticResource NovaMenuHint}" />
                        <TextBlock Text="Neues Fenster" Style="{StaticResource NovaMenuText}" />
                    </DockPanel>
                </Button>
                <Button Style="{StaticResource NovaMenuButton}" Click="Incognito_Click">
                    <DockPanel>
                        <TextBlock Text="&#xE7EE;" Style="{StaticResource NovaMenuIcon}" />
                        <TextBlock DockPanel.Dock="Right" Text="Strg+Shift+N" Style="{StaticResource NovaMenuHint}" />
                        <TextBlock Text="Privates Fenster" Style="{StaticResource NovaMenuText}" />
                    </DockPanel>
                </Button>

                <Border Height="1" Background="#30203d" Margin="10,3,10,3" />

                <Button Height="33" Margin="8,0" Padding="8,0" Background="#211229" BorderBrush="#4a2462" HorizontalContentAlignment="Stretch" Click="Profile_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ProfileRoot" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="13">
                                <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ProfileRoot" Property="Background" Value="#311943" />
                                    <Setter TargetName="ProfileRoot" Property="BorderBrush" Value="#9f4dff" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Right" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" Foreground="#c9a8ff" FontSize="13" VerticalAlignment="Center" />
                        <Border Width="24" Height="24" CornerRadius="12" Background="#0f0714" BorderBrush="#ff2f88" BorderThickness="1" Margin="0,0,8,0">
                            <TextBlock Text="D" Foreground="#ffffff" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Dennis" Foreground="#ffffff" FontSize="12.5" FontWeight="SemiBold" />
                            <TextBlock Text="Angemeldet" Foreground="#c9a8ff" FontSize="11" />
                        </StackPanel>
                    </DockPanel>
                </Button>

                <Border Height="1" Background="#30203d" Margin="10,3,10,3" />

                <Button Style="{StaticResource NovaMenuButton}" Click="Passwords_Click">
                    <DockPanel>
                        <TextBlock Text="&#xE72E;" Style="{StaticResource NovaMenuIcon}" />
                        <TextBlock DockPanel.Dock="Right" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" Foreground="#9f91b6" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="Passwoerter und Autofill" Style="{StaticResource NovaMenuText}" />
                    </DockPanel>
                </Button>
                <Button x:Name="HistoryMenuButton" Style="{StaticResource NovaMenuButton}" Click="HistorySubmenu_Click">
                    <DockPanel>
                        <TextBlock Text="&#xE81C;" Style="{StaticResource NovaMenuIcon}" />
                        <TextBlock DockPanel.Dock="Right" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" Foreground="#9f91b6" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="Verlauf" Style="{StaticResource NovaMenuText}" />
                    </DockPanel>
                </Button>
                <Button Style="{StaticResource NovaMenuButton}" Click="Downloads_Click">
                    <DockPanel>
                        <TextBlock Text="&#xE896;" Style="{StaticResource NovaMenuIcon}" />
                        <TextBlock DockPanel.Dock="Right" Text="Strg+J" Style="{StaticResource NovaMenuHint}" />
                        <TextBlock Text="Downloads" Style="{StaticResource NovaMenuText}" />
                    </DockPanel>
                </Button>
                <Button x:Name="BookmarksMenuButton" Style="{StaticResource NovaMenuButton}" Click="BookmarksSubmenu_Click">
                    <DockPanel>
                        <TextBlock Text="&#xE734;" Style="{StaticResource NovaMenuIcon}" />
                        <TextBlock DockPanel.Dock="Right" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" Foreground="#9f91b6" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="Lesezeichen" Style="{StaticResource NovaMenuText}" />
                    </DockPanel>
                </Button>
                <Button x:Name="TabGroupsMenuButton" Style="{StaticResource NovaMenuButton}" Click="TabGroupsSubmenu_Click">
                    <DockPanel>
                        <TextBlock Text="&#xE8A9;" Style="{StaticResource NovaMenuIcon}" />
                        <TextBlock DockPanel.Dock="Right" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" Foreground="#9f91b6" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="Tabgruppen" Style="{StaticResource NovaMenuText}" />
                    </DockPanel>
                </Button>
                <Button x:Name="ExtensionsMenuButton" Style="{StaticResource NovaMenuButton}" Click="ExtensionsSubmenu_Click">
                    <DockPanel>
                        <TextBlock Text="&#xECAA;" Style="{StaticResource NovaMenuIcon}" />
                        <TextBlock DockPanel.Dock="Right" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" Foreground="#9f91b6" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="Nova Addons" Style="{StaticResource NovaMenuText}" />
                    </DockPanel>
                </Button>
                <Button Style="{StaticResource NovaMenuButton}" Click="ClearData_Click">
                    <DockPanel>
                        <TextBlock Text="&#xE74D;" Style="{StaticResource NovaMenuIcon}" />
                        <TextBlock DockPanel.Dock="Right" Text="Strg+Shift+Entf" Style="{StaticResource NovaMenuHint}" />
                        <TextBlock Text="Browserdaten loeschen" Style="{StaticResource NovaMenuText}" />
                    </DockPanel>
                </Button>

                <Border Height="1" Background="#30203d" Margin="10,3,10,3" />

                <Grid Height="29" Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="31" />
                        <ColumnDefinition Width="46" />
                        <ColumnDefinition Width="31" />
                        <ColumnDefinition Width="31" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#xE721;" Style="{StaticResource NovaMenuIcon}" />
                    <TextBlock Grid.Column="1" Text="Zoom" Style="{StaticResource NovaMenuText}" />
                    <Button Grid.Column="2" Content="&#xE738;" Style="{StaticResource NovaRoundMenuButton}" Click="ZoomOut_Click" />
                    <TextBlock Grid.Column="3" Text="{Binding ZoomText, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="#f8efff" FontSize="13" TextAlignment="Center" VerticalAlignment="Center" />
                    <Button Grid.Column="4" Content="&#xE710;" Style="{StaticResource NovaRoundMenuButton}" Click="ZoomIn_Click" />
                    <Button Grid.Column="5" Content="&#xE740;" Style="{StaticResource NovaRoundMenuButton}" Click="Fullscreen_Click" />
                </Grid>

                <Border Height="1" Background="#30203d" Margin="10,3,10,3" />

                <Button Style="{StaticResource NovaMenuButton}" Click="Print_Click">
                    <DockPanel>
                        <TextBlock Text="&#xE749;" Style="{StaticResource NovaMenuIcon}" />
                        <TextBlock DockPanel.Dock="Right" Text="Strg+P" Style="{StaticResource NovaMenuHint}" />
                        <TextBlock Text="Drucken" Style="{StaticResource NovaMenuText}" />
                    </DockPanel>
                </Button>
                <Button Style="{StaticResource NovaMenuButton}" Click="Lens_Click">
                    <DockPanel>
                        <TextBlock Text="&#xE722;" Style="{StaticResource NovaMenuIcon}" />
                        <TextBlock Text="Visuelle Suche fuer diesen Tab" Style="{StaticResource NovaMenuText}" />
                    </DockPanel>
                </Button>
                <Button Style="{StaticResource NovaMenuButton}" Click="Translate_Click">
                    <DockPanel>
                        <TextBlock Text="&#xE774;" Style="{StaticResource NovaMenuIcon}" />
                        <TextBlock Text="Uebersetzen" Style="{StaticResource NovaMenuText}" />
                    </DockPanel>
                </Button>
                <Button x:Name="FindEditMenuButton" Style="{StaticResource NovaMenuButton}" Click="FindEditSubmenu_Click">
                    <DockPanel>
                        <TextBlock Text="&#xE721;" Style="{StaticResource NovaMenuIcon}" />
                        <TextBlock DockPanel.Dock="Right" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" Foreground="#9f91b6" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="Suchen und bearbeiten" Style="{StaticResource NovaMenuText}" />
                    </DockPanel>
                </Button>
                <Button x:Name="ShareMenuButton" Style="{StaticResource NovaMenuButton}" Click="ShareSubmenu_Click">
                    <DockPanel>
                        <TextBlock Text="&#xE72D;" Style="{StaticResource NovaMenuIcon}" />
                        <TextBlock DockPanel.Dock="Right" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" Foreground="#9f91b6" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="Streamen, speichern und teilen" Style="{StaticResource NovaMenuText}" />
                    </DockPanel>
                </Button>
                <Button x:Name="MoreToolsMenuButton" Style="{StaticResource NovaMenuButton}" Click="MoreToolsSubmenu_Click">
                    <DockPanel>
                        <TextBlock Text="&#xE713;" Style="{StaticResource NovaMenuIcon}" />
                        <TextBlock DockPanel.Dock="Right" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" Foreground="#9f91b6" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="Weitere Tools" Style="{StaticResource NovaMenuText}" />
                    </DockPanel>
                </Button>

                <Border Height="1" Background="#30203d" Margin="10,3,10,3" />

                <Button x:Name="HelpMenuButton" Style="{StaticResource NovaMenuButton}" Click="HelpSubmenu_Click">
                    <DockPanel>
                        <TextBlock Text="&#xE897;" Style="{StaticResource NovaMenuIcon}" />
                        <TextBlock DockPanel.Dock="Right" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" Foreground="#9f91b6" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="Hilfe" Style="{StaticResource NovaMenuText}" />
                    </DockPanel>
                </Button>
                <Button Style="{StaticResource NovaMenuButton}" Click="Settings_Click">
                    <DockPanel>
                        <TextBlock Text="&#xE713;" Style="{StaticResource NovaMenuIcon}" />
                        <TextBlock Text="Einstellungen" Style="{StaticResource NovaMenuText}" />
                    </DockPanel>
                </Button>
                <Button Style="{StaticResource NovaMenuButton}" Click="Exit_Click">
                    <DockPanel>
                        <TextBlock Text="&#xE8BB;" Style="{StaticResource NovaMenuIcon}" />
                        <TextBlock Text="Beenden" Style="{StaticResource NovaMenuText}" />
                    </DockPanel>
                </Button>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
